<Application x:Class="NX_Suite.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="App_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="UI/Estilos/ColoresGlobales.xaml"/>
                <ResourceDictionary Source="UI/Estilos/EstilosBotones.xaml"/>
                <ResourceDictionary Source="UI/Estilos/EstilosTarjetas.xaml"/>
                <ResourceDictionary Source="UI/Estilos/EstilosScrollBars.xaml"/>
                <ResourceDictionary Source="UI/Estilos/EstilosOverlay.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>