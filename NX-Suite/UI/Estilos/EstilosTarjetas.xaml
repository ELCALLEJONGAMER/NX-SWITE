<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controles="clr-namespace:NX_Suite.UI.Controles"
                    xmlns:cfg="clr-namespace:NX_Suite.Core.Configuracion">

    <BooleanToVisibilityConverter x:Key="BoolToVisLocal"/>

    <DataTemplate x:Key="PlantillaNewsItem">
        <Button Style="{StaticResource EstiloBotonNewsItem}"
                Margin="0,0,10,14"
                ToolTip="Abrir noticia">
            <Border x:Name="BordeNews"
                    Height="264"
                    CornerRadius="18"
                    BorderBrush="#2A2A35"
                    BorderThickness="2"
                    Background="{Binding BackgroundColor}"
                    ClipToBounds="True"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect x:Name="SombraNews"
                                      BlurRadius="14"
                                      ShadowDepth="0"
                                      Color="Black"
                                      Opacity="0.55"/>
                </Border.Effect>
                <Grid>
                    <Rectangle Opacity="0.48"
                               RenderOptions.BitmapScalingMode="HighQuality">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="{Binding ImageUrl}"
                                        Stretch="UniformToFill"
                                        AlignmentX="Right"
                                        AlignmentY="Center"/>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F20D0D12" Offset="0"/>
                                <GradientStop Color="#CC0D0D12" Offset="0.58"/>
                                <GradientStop Color="#330D0D12" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Grid Margin="18,14,16,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="ExtraBold"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="44"/>
                        <ScrollViewer Grid.Row="1"
                                      Margin="0,8,90,10"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding Description}"
                                       Foreground="#C0C0D0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.86"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                        <Border Grid.Row="2"
                                HorizontalAlignment="Left"
                                CornerRadius="8"
                                Padding="10,4"
                                Background="#1600D2FF"
                                BorderBrush="#6600D2FF"
                                BorderThickness="1">
                            <TextBlock Text="ABRIR"
                                       Foreground="#00D2FF"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Button>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                <Setter TargetName="BordeNews" Property="BorderBrush" Value="#00D2FF"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="BordeNews"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.015" Duration="0:0:0.16"/>
                            <DoubleAnimation Storyboard.TargetName="BordeNews"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.015" Duration="0:0:0.16"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="BordeNews"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.16"/>
                            <DoubleAnimation Storyboard.TargetName="BordeNews"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.16"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="PlantillaModuloGamer">

        <!-- Grid raíz: capas alineadas, el halo va DETRÁS de la tarjeta -->
        <Grid>

            <!-- ── Halo neon rotatorio por estado ── -->
            <Border x:Name="BordNeonGiro"
                    Width="210" Height="225"
                    Margin="0"
                    CornerRadius="22"
                    BorderThickness="5"
                    BorderBrush="Transparent"
                    Background="Transparent"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <BlurEffect Radius="20"/>
                </Border.Effect>
            </Border>

            <!-- ── Tarjeta principal ── -->
            <Border x:Name="CuerpoTarjeta"
                    Width="180" Height="205"
                    Margin="15"
                    CornerRadius="20"
                    Background="#0F0F15"
                    BorderThickness="5"
                    BorderBrush="#2A2A35"
                    Cursor="Hand"
                    ClipToBounds="True"
                    RenderTransformOrigin="0.5,0.5">

                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>

                <Border.Effect>
                    <DropShadowEffect x:Name="SombraTarjeta"
                                      BlurRadius="14"
                                      ShadowDepth="0"
                                      Color="Black"
                                      Opacity="0.55"/>
                </Border.Effect>

                <Grid ClipToBounds="True">
                    <!-- Clip redondeado que iguala las esquinas interiores de la tarjeta.
                         CuerpoTarjeta: Width=180 Height=205 BorderThickness=5 CornerRadius=20
                         Area interior: 170x195, radio interior: 20-5 = 15 px -->
                    <Grid.Clip>
                        <RectangleGeometry Rect="0,0,170,195" RadiusX="15" RadiusY="15"/>
                    </Grid.Clip>

                    <!-- Glow ambiental de fondo -->
                    <Ellipse x:Name="GlowFondo"
                             Fill="#1A2A2A35"
                             Width="140" Height="140"
                             Margin="-35,-50,0,0"
                             VerticalAlignment="Top"
                             HorizontalAlignment="Left">
                        <Ellipse.Effect>
                            <BlurEffect Radius="50"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- ── Overlay de progreso (relleno verde de abajo arriba) ── -->
                    <Rectangle x:Name="RectProgreso"
                               Opacity="0.55"
                               VerticalAlignment="Bottom"
                               HorizontalAlignment="Stretch"
                               Height="205"
                               RenderTransformOrigin="0.5,1"
                               Visibility="Collapsed">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#C040C057" Offset="0.0"/>
                                <GradientStop Color="#6040C057" Offset="0.55"/>
                                <GradientStop Color="#1A40C057" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.RenderTransform>
                            <ScaleTransform ScaleY="{Binding ProgresoInstalacion}"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <Grid Margin="12,10,12,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <!-- ── FILA 0: caché (izq) + chips versión (der) ── -->
                        <Grid Grid.Row="0">
                            <Grid Width="20" Height="20"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center">
                                <Ellipse x:Name="GlowCache"
                                         Fill="#40C057"
                                         Opacity="0"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <BlurEffect Radius="10"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Image x:Name="ImgCache"
                                       Source="{Binding IconoCacheActual}"
                                       Width="20" Height="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="{Binding CacheOpacity}"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       ToolTip="{Binding TooltipCache}"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Border x:Name="ChipVersionSD"
                                        Background="#2AFFFFFF"
                                        CornerRadius="7"
                                        Padding="10,4"
                                        Margin="0,0,4,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="TxtVersionSD"
                                               Foreground="#707080"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                                <Border x:Name="ChipVersionDisponible"
                                        Background="#2AFFFFFF"
                                        CornerRadius="7"
                                        Padding="10,4"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="TxtVersionDisponible"
                                               Foreground="#00D2FF"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ── FILA 1: icono ── -->
                        <Grid Grid.Row="1" Margin="0,4,0,4">
                            <Image Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                                   Stretch="Uniform"
                                   MaxHeight="68"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                            </Image>
                        </Grid>

                        <!-- ── FILA 2: nombre ── -->
                        <TextBlock Grid.Row="2"
                                   Text="{Binding Nombre}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="ExtraBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxHeight="36"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- ── FILA 4: botón de acción ── -->
                        <controles:SafeButton x:Name="BtnAccion"
                                Grid.Row="4"
                                Height="30"
                                HoldTimeSeconds="2"
                                IsSafeMode="False"
                                Style="{DynamicResource EstiloBotonTarjetaInstalar}"
                                Visibility="{Binding MostrarAccionRapida, Converter={StaticResource BoolToVisLocal}}">
                            <TextBlock x:Name="TxtAccionBtn"
                                       Text="{Binding TextoAccionRapida}"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </controles:SafeButton>

                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <DataTemplate.Triggers>

            <!-- ══════════════════════════════════════════
                 PROGRESO DE INSTALACIÓN EN TARJETA
                 ══════════════════════════════════════════ -->
            <DataTrigger Binding="{Binding EstaInstalando}" Value="True">
                <Setter TargetName="RectProgreso"  Property="Visibility"   Value="Visible"/>
                <Setter TargetName="BtnAccion"     Property="Visibility"   Value="Collapsed"/>
                <Setter TargetName="CuerpoTarjeta" Property="BorderBrush"  Value="#40C057"/>
                <Setter TargetName="BordNeonGiro"  Property="BorderBrush"  Value="{DynamicResource PincelNeonVerde}"/>
                <Setter TargetName="BordNeonGiro"  Property="Opacity"      Value="1"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="GiroHaloInstalando">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="BordNeonGiro"
                                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="GiroHaloInstalando"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- ── Hover ── -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CuerpoTarjeta" Property="Background" Value="#14141E"/>
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CuerpoTarjeta"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                             To="1.04" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="CuerpoTarjeta"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                             To="1.04" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="BordNeonGiro"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.04" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="BordNeonGiro"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.04" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="BlurRadius"
                                             To="24" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.7" Duration="0:0:0.18"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CuerpoTarjeta"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                             To="1" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="CuerpoTarjeta"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                             To="1" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="BordNeonGiro"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="BordNeonGiro"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="BlurRadius"
                                             To="14" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.55" Duration="0:0:0.18"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>

            <!-- ── Caché ── -->
            <DataTrigger Binding="{Binding TieneCache}" Value="True">
                <Setter TargetName="GlowCache" Property="Opacity" Value="0.9"/>
            </DataTrigger>

            <!-- ══════════════════════════════════════════
                 ESTADOS SD  +  halo neon rotatorio
                 ══════════════════════════════════════════ -->

            <DataTrigger Binding="{Binding EstadoSd}" Value="NoInstalado">
                <Setter TargetName="CuerpoTarjeta"       Property="BorderBrush" Value="#2A2A35"/>
                <Setter TargetName="GlowFondo"           Property="Fill"        Value="#0A2A2A35"/>
                <Setter TargetName="ChipVersionDisponible" Property="Visibility" Value="Visible"/>
                <Setter TargetName="TxtVersionDisponible"  Property="Text"
                        Value="{Binding Versiones[0].Version}"/>
                <Setter TargetName="TxtVersionDisponible"  Property="Foreground" Value="#707080"/>
                <Setter TargetName="ChipVersionDisponible" Property="Background" Value="#1A2A2A35"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding EstadoSd}" Value="Instalado">
                <Setter TargetName="CuerpoTarjeta"  Property="BorderBrush" Value="#40C057"/>
                <Setter TargetName="GlowFondo"      Property="Fill"        Value="#1240C057"/>
                <Setter TargetName="ChipVersionSD"  Property="Visibility"  Value="Visible"/>
                <Setter TargetName="TxtVersionSD"   Property="Text"        Value="{Binding VersionInstalada}"/>
                <Setter TargetName="ChipVersionSD"  Property="Background"  Value="#1440C057"/>
                <Setter TargetName="TxtVersionSD"   Property="Foreground"  Value="#40C057"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="SombraTarjeta"
                                            Storyboard.TargetProperty="Color"
                                            To="#40C057" Duration="0"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.3" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="SombraTarjeta"
                                            Storyboard.TargetProperty="Color"
                                            To="Black" Duration="0"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.55" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding EstadoSd}" Value="ParcialmenteInstalado">
                <Setter TargetName="CuerpoTarjeta" Property="BorderBrush" Value="#FF6B00"/>
                <Setter TargetName="GlowFondo"     Property="Fill"        Value="#12FF6B00"/>
                <Setter TargetName="ChipVersionSD" Property="Visibility"  Value="Visible"/>
                <Setter TargetName="TxtVersionSD"  Property="Text"        Value="PARCIAL"/>
                <Setter TargetName="TxtVersionSD"  Property="Foreground"  Value="#FF6B00"/>
                <Setter TargetName="ChipVersionSD" Property="Background"  Value="#14FF6B00"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="SombraTarjeta"
                                            Storyboard.TargetProperty="Color"
                                            To="#FF6B00" Duration="0"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.25" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="SombraTarjeta"
                                            Storyboard.TargetProperty="Color"
                                            To="Black" Duration="0"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.55" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                        </DataTrigger.ExitActions>
                    </DataTrigger>

                    <!-- ══════════════════════════════════════════
                         ACCIÓN RÁPIDA  +  halo ámbar en "Actualizar"
                 ══════════════════════════════════════════ -->

            <DataTrigger Binding="{Binding AccionRapida}" Value="Instalar">
                <Setter TargetName="BtnAccion" Property="Style"
                        Value="{DynamicResource EstiloBotonTarjetaInstalar}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding AccionRapida}" Value="Actualizar">
                <Setter TargetName="BtnAccion"     Property="Style"       Value="{DynamicResource EstiloBotonTarjetaAmbar}"/>
                <Setter TargetName="CuerpoTarjeta" Property="BorderBrush" Value="#FFD54A"/>
                <Setter TargetName="GlowFondo"     Property="Fill"        Value="#12FFD54A"/>
                <Setter TargetName="ChipVersionSD"         Property="Visibility" Value="Visible"/>
                <Setter TargetName="ChipVersionDisponible" Property="Visibility" Value="Visible"/>
                <Setter TargetName="TxtVersionDisponible"  Property="Foreground" Value="#FFD54A"/>
                <Setter TargetName="ChipVersionDisponible" Property="Background" Value="#14FFD54A"/>
                <!-- Halo ámbar (sobreescribe el verde/naranja del estado) -->
                <Setter TargetName="BordNeonGiro" Property="BorderBrush" Value="{DynamicResource PincelSpotAmbar}"/>
                <Setter TargetName="BordNeonGiro" Property="Opacity"     Value="1"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="SombraTarjeta"
                                            Storyboard.TargetProperty="Color"
                                            To="#FFD54A" Duration="0"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.3" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                    <BeginStoryboard x:Name="GiroHaloAmbar">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="BordNeonGiro"
                                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:2.5" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="SombraTarjeta"
                                            Storyboard.TargetProperty="Color"
                                            To="Black" Duration="0"/>
                            <DoubleAnimation Storyboard.TargetName="SombraTarjeta"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.55" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                    <StopStoryboard BeginStoryboardName="GiroHaloAmbar"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding AccionRapida}" Value="Reinstalar">
                <Setter TargetName="BtnAccion" Property="Style"
                        Value="{DynamicResource EstiloBotonTarjetaAmbar}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding AccionRapida}" Value="Eliminar">
                <Setter TargetName="BtnAccion" Property="Style"
                        Value="{DynamicResource EstiloBotonTarjetaEliminarHold}"/>
                <Setter TargetName="BtnAccion" Property="IsSafeMode" Value="True"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding AccionRapida}" Value="DescargarCache">
                <Setter TargetName="BtnAccion" Property="Style"
                        Value="{DynamicResource EstiloBotonTarjetaInstalar}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding AccionRapida}" Value="EliminarCache">
                <Setter TargetName="BtnAccion" Property="Style"
                        Value="{DynamicResource EstiloBotonTarjetaEliminarHold}"/>
                <Setter TargetName="BtnAccion" Property="IsSafeMode" Value="True"/>
            </DataTrigger>

        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ================================================================
         PLANTILLA COMPACTA PARA VISTA ASISTIDA
         Misma estetica gamer, sin botones de accion.
         Click en la tarjeta = seleccionar. Icono info en esquina = detalles.
         ================================================================ -->
    <DataTemplate x:Key="PlantillaTarjetaAsistida">
        <Grid>
            <!-- Halo neon rotatorio -->
            <Border x:Name="HaloAsist"
                    Width="195" Height="185"
                    CornerRadius="22"
                    BorderThickness="5"
                    BorderBrush="Transparent"
                    Background="Transparent"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <BlurEffect Radius="20"/>
                </Border.Effect>
            </Border>

            <!-- Tarjeta principal -->
            <Border x:Name="CuerpoAsist"
                    Width="175" Height="165"
                    Margin="10"
                    CornerRadius="16"
                    Background="#0F0F15"
                    BorderThickness="1.5"
                    BorderBrush="#2A2A35"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect x:Name="SombraAsist"
                                      BlurRadius="12" ShadowDepth="0"
                                      Color="Black" Opacity="0.7"/>
                </Border.Effect>

                <Grid ClipToBounds="True">

                    <!-- Glow ambiental -->
                    <Ellipse x:Name="GlowAsist"
                             Fill="#1A2A2A35"
                             Width="120" Height="120"
                             Margin="-30,-40,0,0"
                             VerticalAlignment="Top" HorizontalAlignment="Left">
                        <Ellipse.Effect>
                            <BlurEffect Radius="45"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <Grid Margin="10,8,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                        </Grid.RowDefinitions>

                        <!-- FILA 0: boton info (izq) + estado badge (der) -->
                        <Grid Grid.Row="0">
                            <Border x:Name="BadgeEstadoAsist"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    CornerRadius="6" Padding="7,2"
                                    Background="#1A2A2A35"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="TxtBadgeAsist"
                                           FontSize="8" FontWeight="Bold"
                                           Foreground="#707080"/>
                            </Border>

                            <!-- Boton info - esquina superior izquierda -->
                            <Border x:Name="BtnInfoAsist"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Width="22" Height="22"
                                    CornerRadius="11"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Opacity="0.75"
                                    Cursor="Hand"
                                    RenderTransformOrigin="0.5,0.5"
                                    ToolTip="Ver detalles">
                                <Border.RenderTransform>
                                    <ScaleTransform/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 To="1.25" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 To="1.25" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1.0" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 To="1" Duration="0:0:0.12"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 To="1" Duration="0:0:0.12"/>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0.75" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeftButtonDown">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 To="0.82" Duration="0:0:0.05"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 To="0.82" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeftButtonUp">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 To="1.15" Duration="0:0:0.09"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 To="1.15" Duration="0:0:0.09"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <!-- PNG del gist; si no carga, muestra el ℹ unicode -->
                                <Grid>
                                    <TextBlock Text="&#x2139;"
                                               FontSize="14"
                                               FontFamily="Segoe UI Emoji"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Opacity="0.6"/>
                                    <Image Source="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoInfoUrl, Converter={StaticResource IconoCacheConverter}}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- FILA 1: icono -->
                        <Grid Grid.Row="1" Margin="0,2,0,2">
                            <Image Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                                   Stretch="Uniform" MaxHeight="64"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>

                        <!-- FILA 2: nombre -->
                        <TextBlock Grid.Row="2"
                                   Text="{Binding Nombre}"
                                   Foreground="White"
                                   FontSize="14" FontWeight="ExtraBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxHeight="32"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- FILA 3: version -->
                        <TextBlock x:Name="TxtVerAsist" Grid.Row="3"
                                   Foreground="#50FFFFFF"
                                   FontSize="12" FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Text="{Binding Versiones[0].Version, FallbackValue=''}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <DataTemplate.Triggers>

            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CuerpoAsist" Property="Background" Value="#14141E"/>
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CuerpoAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                             To="1.04" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="CuerpoAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                             To="1.04" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="HaloAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                             To="1.04" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="HaloAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                             To="1.04" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="SombraAsist"
                                             Storyboard.TargetProperty="BlurRadius"
                                             To="22" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CuerpoAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                             To="1" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="CuerpoAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                             To="1" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="HaloAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                             To="1" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="HaloAsist"
                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                             To="1" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetName="SombraAsist"
                                             Storyboard.TargetProperty="BlurRadius"
                                             To="12" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>

            <!-- Estado: Instalado -->
            <DataTrigger Binding="{Binding EstadoSd}" Value="Instalado">
                <Setter TargetName="CuerpoAsist"    Property="BorderBrush" Value="#40C057"/>
                <Setter TargetName="GlowAsist"      Property="Fill"        Value="#1240C057"/>
                <Setter TargetName="BadgeEstadoAsist" Property="Visibility" Value="Visible"/>
                <Setter TargetName="BadgeEstadoAsist" Property="Background" Value="#1440C057"/>
                <Setter TargetName="TxtBadgeAsist"  Property="Text"        Value="EN SD"/>
                <Setter TargetName="TxtBadgeAsist"  Property="Foreground"  Value="#40C057"/>
                <Setter TargetName="HaloAsist"      Property="BorderBrush" Value="{StaticResource PincelSpotVerde}"/>
                <Setter TargetName="HaloAsist"      Property="Opacity"     Value="1"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="HaloVerdeA">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="HaloAsist"
                                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                            <ColorAnimation Storyboard.TargetName="SombraAsist"
                                            Storyboard.TargetProperty="Color"
                                            To="#40C057" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="HaloVerdeA"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- Estado: No instalado -->
            <DataTrigger Binding="{Binding EstadoSd}" Value="NoInstalado">
                <Setter TargetName="HaloAsist" Property="BorderBrush" Value="{StaticResource PincelSpotGris}"/>
                <Setter TargetName="HaloAsist" Property="Opacity"     Value="1"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="HaloGrisA">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="HaloAsist"
                                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:6" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="HaloGrisA"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- Seleccionado en modo asistido -->
            <DataTrigger Binding="{Binding EstaSeleccionadoAsistido}" Value="True">
                <Setter TargetName="CuerpoAsist" Property="BorderBrush" Value="#40C057"/>
                <Setter TargetName="GlowAsist"   Property="Fill"        Value="#1240C057"/>
                <Setter TargetName="HaloAsist"   Property="BorderBrush" Value="{StaticResource PincelSpotVerde}"/>
                <Setter TargetName="HaloAsist"   Property="Opacity"     Value="1"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="HaloVerdeSelAsist">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="HaloAsist"
                                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:2.5" RepeatBehavior="Forever"/>
                            <ColorAnimation Storyboard.TargetName="SombraAsist"
                                            Storyboard.TargetProperty="Color"
                                            To="#40C057" Duration="0"/>
                            <DoubleAnimation Storyboard.TargetName="SombraAsist"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.55" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="HaloVerdeSelAsist"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- Estado: Parcial -->
            <DataTrigger Binding="{Binding EstadoSd}" Value="ParcialmenteInstalado">
                <Setter TargetName="CuerpoAsist"    Property="BorderBrush" Value="#FF6B00"/>
                <Setter TargetName="GlowAsist"      Property="Fill"        Value="#12FF6B00"/>
                <Setter TargetName="BadgeEstadoAsist" Property="Visibility" Value="Visible"/>
                <Setter TargetName="BadgeEstadoAsist" Property="Background" Value="#14FF6B00"/>
                <Setter TargetName="TxtBadgeAsist"  Property="Text"        Value="PARCIAL"/>
                <Setter TargetName="TxtBadgeAsist"  Property="Foreground"  Value="#FF6B00"/>
                <Setter TargetName="HaloAsist"      Property="BorderBrush" Value="{StaticResource PincelSpotNaranja}"/>
                <Setter TargetName="HaloAsist"      Property="Opacity"     Value="1"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="HaloNaranjaA">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="HaloAsist"
                                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                            <ColorAnimation Storyboard.TargetName="SombraAsist"
                                            Storyboard.TargetProperty="Color"
                                            To="#FF6B00" Duration="0"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="HaloNaranjaA"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>