    <Style x:Key="EstiloItemNeonBase" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="LedBorder"
                            Width="190"
                            Height="70"
                            CornerRadius="10"
                            BorderThickness="2"
                            BorderBrush="{StaticResource BordeGeneral}"
                            Background="{StaticResource FondoOscuro}"
                            Margin="0,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter TargetName="LedBorder" Property="Background" Value="#1A1A25"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroNeonSeleccion">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder"
                                                         Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:3"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroNeonSeleccion"/>
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroNeonHover">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder"
                                                         Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:3"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroNeonHover"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloItemMundoGamer"
           TargetType="ListBoxItem"
           BasedOn="{StaticResource EstiloItemNeonBase}">
        <Setter Property="Height" Value="72"/>
        <Setter Property="Margin" Value="10,4"/>
    </Style>

    <Style x:Key="EstiloItemCategoriaGamer"
           TargetType="ListBoxItem"
           BasedOn="{StaticResource EstiloItemNeonBase}">
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="0,5"/>
        <Setter Property="Background" Value="{StaticResource FondoPaneles}"/>
    </Style>

    <DataTemplate x:Key="PlantillaItemMundo">
        <Grid Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="46"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="ImgIconoMundo"
                   Source="{Binding IconoUrl}"
                   Width="50"
                   Height="50"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Opacity="0.60"/>

            <TextBlock x:Name="TxtNombreMundo"
                       Grid.Column="1"
                       Text="{Binding Nombre}"
                       Foreground="{StaticResource TextoPrimario}"
                       FontSize="11"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Margin="20,0,0,0"
                       Opacity="0.60"/>
        </Grid>

        <DataTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ImgIconoMundo" Property="Opacity" Value="0.30"/>
                <Setter TargetName="TxtNombreMundo" Property="Opacity" Value="0.35"/>
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoMundo" Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreMundo" Property="Opacity" Value="1"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoMundo" Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreMundo" Property="Opacity" Value="1"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

