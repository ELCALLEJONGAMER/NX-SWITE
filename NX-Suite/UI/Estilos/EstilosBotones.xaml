<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ColoresGlobales.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="EstiloNavPersistente" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="LedBorder" CornerRadius="15" BorderThickness="2" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoOscuro}" Height="75" Margin="10,5">
                        <StackPanel VerticalAlignment="Center">
                            <Image x:Name="Icono" Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Width="32" Height="32" Margin="0,0,0,8" Opacity="0.7"/>
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter TargetName="Icono" Property="Opacity" Value="1.0"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroNav">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroNav"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloBotonIconoNeon" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Height" Value="75"/>
        <Setter Property="Margin" Value="10,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="LedBorder" CornerRadius="15" BorderThickness="2" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoOscuro}">
                        <StackPanel VerticalAlignment="Center">
                            <Image x:Name="Icono" Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Width="32" Height="32" Margin="0,0,0,8" Opacity="0.7"/>
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="Giro">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="Giro"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloBotonMenu" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="LedBorder" CornerRadius="12" BorderThickness="3" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoPaneles}">
                        <ContentPresenter VerticalAlignment="Center" Margin="15,0" HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="SBRot">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SBRot"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloBotonCerrar" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#555"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="10,5">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloOpcionGamer" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Borde" CornerRadius="8" BorderThickness="2" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoPaneles}" Height="35">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Borde" Property="BorderBrush" Value="{StaticResource AcentoCian}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloItemNeonBase" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="LedBorder"
                            Width="150"
                            Height="50"
                            CornerRadius="10"
                            BorderThickness="2"
                            BorderBrush="{StaticResource BordeGeneral}"
                            Background="{StaticResource FondoOscuro}"
                            Margin="0,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter TargetName="LedBorder" Property="Background" Value="#1A1A25"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroNeonSeleccion">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder"
                                                         Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:3"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroNeonSeleccion"/>
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroNeonHover">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder"
                                                         Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:3"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroNeonHover"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloItemMundoGamer"
           TargetType="ListBoxItem"
           BasedOn="{StaticResource EstiloItemNeonBase}">
        <Setter Property="Height" Value="72"/>
        <Setter Property="Margin" Value="10,4"/>
    </Style>

    <Style x:Key="EstiloItemCategoriaGamer"
           TargetType="ListBoxItem"
           BasedOn="{StaticResource EstiloItemNeonBase}">
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="0,5"/>
        <Setter Property="Background" Value="{StaticResource FondoPaneles}"/>
    </Style>

    <DataTemplate x:Key="PlantillaItemMundo">
        <Grid Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="46"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="ImgIconoMundo"
                   Source="{Binding IconoUrl}"
                   Width="30"
                   Height="30"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Opacity="0.60"/>

            <TextBlock x:Name="TxtNombreMundo"
                       Grid.Column="1"
                       Text="{Binding Nombre}"
                       Foreground="{StaticResource TextoPrimario}"
                       FontSize="11"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,0"
                       Opacity="0.60"/>
        </Grid>

        <DataTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ImgIconoMundo" Property="Opacity" Value="0.30"/>
                <Setter TargetName="TxtNombreMundo" Property="Opacity" Value="0.35"/>
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoMundo" Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreMundo" Property="Opacity" Value="1"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoMundo" Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreMundo" Property="Opacity" Value="1"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style x:Key="EstiloBotonAccionBase" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="LedBorder"
                            
                            CornerRadius="12"
                            BorderThickness="3"
                            BorderBrush="{StaticResource BordeGeneral}"
                            Background="{StaticResource FondoPaneles}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush"
                                    Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroAccion">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="LedBorder"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                            From="0" To="360"
                                            Duration="0:0:3"
                                            RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroAccion"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloBotonInstalar" TargetType="Button" BasedOn="{StaticResource EstiloBotonAccionBase}">
        <Setter Property="Margin" Value="5"/>
    </Style>

    <Style x:Key="EstiloBotonActualizar" TargetType="Button" BasedOn="{StaticResource EstiloBotonAccionBase}">
        <Setter Property="Margin" Value="5"/>
    </Style>

    <Style x:Key="EstiloBotonEliminar" TargetType="Button" BasedOn="{StaticResource EstiloBotonAccionBase}">
        <Setter Property="Margin" Value="5"/>
    </Style>

    <Style x:Key="EstiloBotonVolver" TargetType="Button" BasedOn="{StaticResource EstiloBotonAccionBase}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Width" Value="220"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
    </Style>

    <Style x:Key="EstiloComboOscuro" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource AcentoCian}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Style.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#15151C" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A2A35" />
        </Style.Resources>
    </Style>

    <Style x:Key="EstiloItemFiltroGamer"
           TargetType="ListBoxItem"
           BasedOn="{StaticResource EstiloItemNeonBase}">
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="6,5"/>
    </Style>

    <DataTemplate x:Key="PlantillaFiltroCentroMando">
        <Grid Margin="6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="ImgIconoFiltro"
                   Source="{Binding IconoUrl}"
                   Width="16"
                   Height="16"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Opacity="0.35"/>

            <TextBlock x:Name="TxtNombreFiltro"
                       Grid.Column="1"
                       Text="{Binding Nombre}"
                       Foreground="{StaticResource TextoPrimario}"
                       FontSize="10"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Margin="8,0,8,0"
                       Opacity="0.45"/>
        </Grid>

        <DataTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ImgIconoFiltro" Property="Opacity" Value="0.25"/>
                <Setter TargetName="TxtNombreFiltro" Property="Opacity" Value="0.45"/>
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoFiltro" Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreFiltro" Property="Opacity" Value="1"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoFiltro" Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreFiltro" Property="Opacity" Value="1"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ════════════════════════════════════════════
         BOTONES DE TARJETA  –  neon por tipo acción
         ════════════════════════════════════════════ -->

    <!-- DETALLES → cian / púrpura -->
    <Style x:Key="EstiloBotonTarjetaDetalles" TargetType="Button">
        <Setter Property="Foreground"  Value="{StaticResource AcentoCian}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AcentoCian}"/>
        <Setter Property="Background"  Value="#0DFFFFFF"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="GlowNeon"
                                CornerRadius="10" Margin="-4"
                                Opacity="0.35" BorderThickness="4"
                                BorderBrush="{StaticResource AcentoCian}">
                            <Border.Effect>
                                <BlurEffect Radius="16"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Borde"
                                CornerRadius="10" BorderThickness="2"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde"    Property="Background"   Value="#1AFFFFFF"/>
                            <Setter TargetName="GlowNeon" Property="Opacity"      Value="1.0"/>
                            <Setter TargetName="GlowNeon" Property="BorderBrush"  Value="{StaticResource PincelNeonRotatorio}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroDet">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlowNeon"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroDet"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde"    Property="Background" Value="#08FFFFFF"/>
                            <Setter TargetName="GlowNeon" Property="Opacity"    Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- INSTALAR → verde / cian -->
    <Style x:Key="EstiloBotonTarjetaInstalar" TargetType="Button">
        <Setter Property="Foreground"  Value="{StaticResource AcentoVerde}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AcentoVerde}"/>
        <Setter Property="Background"  Value="#0DFFFFFF"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="GlowNeon"
                                CornerRadius="10" Margin="-4"
                                Opacity="0.35" BorderThickness="4"
                                BorderBrush="{StaticResource AcentoVerde}">
                            <Border.Effect>
                                <BlurEffect Radius="16"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Borde"
                                CornerRadius="10" BorderThickness="2"
                                BorderBrush="{TemplateBinding Background}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde"    Property="Background"  Value="#1AFFFFFF"/>
                            <Setter TargetName="GlowNeon" Property="Opacity"     Value="1.0"/>
                            <Setter TargetName="GlowNeon" Property="BorderBrush" Value="{StaticResource PincelNeonVerde}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroIns">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlowNeon"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroIns"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde"    Property="Background" Value="#08FFFFFF"/>
                            <Setter TargetName="GlowNeon" Property="Opacity"    Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

