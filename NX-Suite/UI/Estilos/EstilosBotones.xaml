    <DataTemplate x:Key="PlantillaFiltroCentroMando">
        <Grid Margin="6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColIcono" Width="26"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="ImgIconoFiltro"
                   Source="{Binding IconoUrl}"
                   Width="18" Height="18"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Opacity="0.5"/>

            <TextBlock x:Name="TxtNombreFiltro"
                       Grid.Column="1"
                       Text="{Binding Nombre}"
                       Foreground="{StaticResource TextoPrimario}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Margin="8,0,6,0"
                       Opacity="0.55"/>
        </Grid>

        <DataTemplate.Triggers>
            <!-- Sin icono: colapsar columna del icono -->
            <DataTrigger Binding="{Binding IconoUrl}" Value="">
                <Setter TargetName="ImgIconoFiltro" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ImgIconoFiltro" Property="Width"      Value="0"/>
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected,  RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ImgIconoFiltro"  Property="Opacity" Value="0.35"/>
                <Setter TargetName="TxtNombreFiltro" Property="Opacity" Value="0.45"/>
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoFiltro"  Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreFiltro" Property="Opacity" Value="1"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="ImgIconoFiltro"  Property="Opacity" Value="1"/>
                <Setter TargetName="TxtNombreFiltro" Property="Opacity" Value="1"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

