                                            From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroAmb"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde"    Property="Background" Value="#08FFFFFF"/>
                            <Setter TargetName="GlowNeon" Property="Opacity"    Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TOP BAR → minimizar (neutro) -->
    <Style x:Key="EstiloBotonTopBar" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Fondo" CornerRadius="6"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Fondo" Property="Background" Value="#20FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Fondo" Property="Background" Value="#30FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TOP BAR → cerrar (rojo en hover) -->
    <Style x:Key="EstiloBotonTopBarCerrar" TargetType="Button"
           BasedOn="{StaticResource EstiloBotonTopBar}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#44FF4444"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#66FF2222"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ELIMINAR → rojo / púrpura -->
    <Style x:Key="EstiloBotonTarjetaEliminar" TargetType="Button">
        <Setter Property="Foreground"  Value="{StaticResource AcentoRojo}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AcentoRojo}"/>
        <Setter Property="Background"  Value="#0DFFFFFF"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="GlowNeon"
                                CornerRadius="10" Margin="-4"
                                Opacity="0.35" BorderThickness="4"
                                BorderBrush="{StaticResource AcentoRojo}">
                            <Border.Effect>
                                <BlurEffect Radius="16"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Borde"
                                CornerRadius="10" BorderThickness="2"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde"    Property="Background"  Value="#1AFFFFFF"/>
                            <Setter TargetName="GlowNeon" Property="Opacity"     Value="1.0"/>
                            <Setter TargetName="GlowNeon" Property="BorderBrush" Value="{StaticResource PincelNeonRojo}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroRoj">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlowNeon"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroRoj"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde"    Property="Background" Value="#08FFFFFF"/>
                            <Setter TargetName="GlowNeon" Property="Opacity"    Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>