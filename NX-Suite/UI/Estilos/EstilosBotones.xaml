    <!-- ════════════════════════════════════════════
         CHIPS DE FILTRO HORIZONTAL (barra superior)
         ════════════════════════════════════════════ -->
    <Style x:Key="EstiloItemChipFiltro" TargetType="ListBoxItem">
        <Setter Property="Background"                Value="Transparent"/>
        <Setter Property="Cursor"                    Value="Hand"/>
        <Setter Property="Foreground"                Value="{StaticResource TextoSecundario}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"  Value="Center"/>
        <Setter Property="Margin"                    Value="0,0,8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ChipBorder"
                            Height="30"
                            Width="150"
                            CornerRadius="5"
                            BorderThickness="2"
                            BorderBrush="{StaticResource BordeGeneral}"
                            Background="{StaticResource FondoOscuro}"
                            Padding="4,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter TargetName="ChipBorder" Property="Background"  Value="#1A1A25"/>
                            <Setter Property="Foreground"   Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroChipSel">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ChipBorder"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroChipSel"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground"   Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroChipHover">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ChipBorder"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroChipHover"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

