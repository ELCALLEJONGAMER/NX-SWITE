                            <Setter TargetName="GlowNeon" Property="BorderBrush" Value="{StaticResource PincelNeonAmbar}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroAmb">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlowNeon"
