    <Style x:Key="EstiloBotonCerrar" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#555"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

