<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ColoresGlobales.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="EstiloNavPersistente" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="LedBorder" CornerRadius="15" BorderThickness="2" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoOscuro}" Height="75" Margin="10,5">
                        <StackPanel VerticalAlignment="Center">
                            <Image x:Name="Icono" Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Width="32" Height="32" Margin="0,0,0,8" Opacity="0.7"/>
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter TargetName="Icono" Property="Opacity" Value="1.0"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroNav">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroNav"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloBotonIconoNeon" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Height" Value="75"/>
        <Setter Property="Margin" Value="10,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="LedBorder" CornerRadius="15" BorderThickness="2" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoOscuro}">
                        <StackPanel VerticalAlignment="Center">
                            <Image x:Name="Icono" Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Width="32" Height="32" Margin="0,0,0,8" Opacity="0.7"/>
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="Giro">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="Giro"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloBotonMenu" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="LedBorder" CornerRadius="12" BorderThickness="3" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoPaneles}">
                        <ContentPresenter VerticalAlignment="Center" Margin="15,0" HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="SBRot">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SBRot"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloBotonCerrar" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#555"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="10,5">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloOpcionGamer" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Borde" CornerRadius="8" BorderThickness="2" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoPaneles}" Height="35">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Borde" Property="BorderBrush" Value="{StaticResource AcentoCian}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloItemMundoGamer" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="LedBorder" CornerRadius="15" BorderThickness="2" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoOscuro}" Margin="10,5" Height="75">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter TargetName="LedBorder" Property="Background" Value="#1A1A25"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroMundoSel">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroMundoSel"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="PlantillaItemMundo">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
            <Image Source="{Binding IconoUrl}" Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding Nombre}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>
    </DataTemplate>


    <Style x:Key="EstiloItemCategoriaGamer" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="LedBorder" CornerRadius="12" BorderThickness="3" BorderBrush="{StaticResource BordeGeneral}" Background="{StaticResource FondoPaneles}" Height="35" Margin="0,5">
                        <ContentPresenter VerticalAlignment="Center" Margin="15,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="GiroSel">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LedBorder" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GiroSel"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LedBorder" Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EstiloComboOscuro" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource AcentoCian}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Style.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#15151C" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A2A35" />
        </Style.Resources>
    </Style>

</ResourceDictionary>