    <Style x:Key="EstiloComboOscuro" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource AcentoCian}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Style.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#15151C" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A2A35" />
        </Style.Resources>
