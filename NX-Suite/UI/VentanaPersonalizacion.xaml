<Window x:Class="NX_Suite.UI.VentanaPersonalizacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NX-Suite - Personalizacion de Hekate"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Width="1100" Height="720"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NX-Suite;component/UI/Estilos/ColoresGlobales.xaml"/>
                <ResourceDictionary Source="/NX-Suite;component/UI/Estilos/EstilosBotones.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Tarjeta slot: mismo estilo que el catalogo (shadow, scale hover, neon border) -->
            <Style x:Key="EstiloSlotHekate" TargetType="Border">
                <Setter Property="CornerRadius"          Value="16"/>
                <Setter Property="BorderThickness"       Value="2"/>
                <Setter Property="BorderBrush"           Value="#2A2A35"/>
                <Setter Property="Background"            Value="#0F0F15"/>
                <Setter Property="Cursor"                Value="Hand"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="Black" Opacity="0.55"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource PincelNeonRotatorio}"/>
                        <Setter Property="Background"  Value="{StaticResource FondoOscuro}"/>
                    </Trigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                                 From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1.015" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1.015" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- Estilo TextBox minimalista -->
            <Style x:Key="TxtHexStyle" TargetType="TextBox">
                <Setter Property="Background"     Value="#0A0A10"/>
                <Setter Property="Foreground"     Value="#00D2FF"/>
                <Setter Property="BorderBrush"    Value="#2A2A35"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize"       Value="11"/>
                <Setter Property="FontFamily"     Value="Consolas"/>
                <Setter Property="Padding"        Value="6,3"/>
                <Setter Property="MaxLength"      Value="7"/>
                <Setter Property="CaretBrush"     Value="#00D2FF"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="15" Background="#0D0D12" BorderBrush="#2A2A35" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Top bar ── -->
            <Border Grid.Row="0" Background="#0F0F16" BorderBrush="#2A2A35"
                    BorderThickness="0,0,0,1" CornerRadius="15,15,0,0">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="NX" Foreground="#00D2FF" FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text=" - Personalizacion de Hekate" Foreground="#707080" FontSize="13" FontWeight="SemiBold"/>
                        <Border Background="#1500D2FF" CornerRadius="5" Padding="7,2" Margin="10,0,0,0">
                            <TextBlock Text="BMP 32-bit" Foreground="#00D2FF" FontSize="9" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="SD:" Foreground="#505060" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="ComboSD" Width="150" Height="26"
                                  Style="{StaticResource EstiloComboOscuro}"
                                  SelectionChanged="ComboSD_SelectionChanged"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Contenido principal: 2 columnas ── -->
            <Grid Grid.Row="1" Margin="14,12,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ Columna izquierda: slots de imagenes ═══ -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <!-- 6 columnas: BootLogo+Background cada uno span 3, iconos span 2 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ══ BOOTLOGO ══ -->
                        <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" x:Name="SlotBootlogo" Tag="bootlogo"
                                Style="{StaticResource EstiloSlotHekate}"
                                AllowDrop="True" Drop="Slot_Drop" DragOver="Slot_DragOver"
                                DragLeave="Slot_DragLeave" MouseLeftButtonDown="Slot_Click">
                            <Grid ClipToBounds="True">
                                <!-- Glow ambiental — igual al catalogo -->
                                <Ellipse Fill="#1A0066FF" Width="200" Height="100"
                                         Margin="-40,-30,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Ellipse.Effect><BlurEffect Radius="45"/></Ellipse.Effect>
                                </Ellipse>
                                <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="250"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Header slot -->
                                <Grid Margin="10,8,10,4">
                                    <StackPanel>
                                        <TextBlock Text="BootLogo" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="bootlogo.bmp" Foreground="#00D2FF" FontSize="8" FontWeight="Bold" Margin="0,0,6,0"/>
                                            <TextBlock Text="/bootloader/" Foreground="#505060" FontSize="8"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="5" Padding="6,2" Background="#0D0D12"
                                            BorderBrush="#2A2A35" BorderThickness="1">
                                        <TextBlock Text="720 x 1280" Foreground="#505060" FontSize="8"/>
                                    </Border>
                                </Grid>
                                <!-- Preview area -->
                                <Border Grid.Row="1" Margin="10,0" CornerRadius="10"
                                        Background="#080810" BorderBrush="#1A1A24" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <StackPanel x:Name="EmptyBootlogo" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="+" FontSize="20" Foreground="#252530" HorizontalAlignment="Center" FontWeight="Light"/>
                                            <TextBlock Text="Arrastra o clic" Foreground="#303040" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Image x:Name="PreviewBootlogo" Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Margin="4" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <!-- Footer estado -->
                                <Grid Grid.Row="2" Margin="10,4,10,8">
                                    <TextBlock x:Name="EstadoBootlogo" Text="Sin imagen" Foreground="#404050" FontSize="8" VerticalAlignment="Center"/>
                                    <Button x:Name="QuitarBootlogo" Content="Quitar" FontSize="12"
                                            HorizontalAlignment="Right" Height="16" Padding="6,0"
                                            Visibility="Collapsed" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Foreground="#505060"
                                            Tag="bootlogo" Click="BtnQuitar_Click"/>
                                </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ══ BACKGROUND ══ -->
                        <Border Grid.Column="4" Grid.ColumnSpan="3" Grid.Row="0" x:Name="SlotBackground" Tag="background"
                                Style="{StaticResource EstiloSlotHekate}"
                                AllowDrop="True" Drop="Slot_Drop" DragOver="Slot_DragOver"
                                DragLeave="Slot_DragLeave" MouseLeftButtonDown="Slot_Click">
                            <Grid ClipToBounds="True">
                                <Ellipse Fill="#1A6600FF" Width="250" Height="250"
                                         Margin="-40,-30,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Ellipse.Effect><BlurEffect Radius="45"/></Ellipse.Effect>
                                </Ellipse>
                                <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="250"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="10,8,10,4">
                                    <StackPanel>
                                        <TextBlock Text="Background" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="background.bmp" Foreground="#00D2FF" FontSize="8" FontWeight="Bold" Margin="0,0,6,0"/>
                                            <TextBlock Text="/bootloader/res/" Foreground="#505060" FontSize="8"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="5" Padding="6,2" Background="#0D0D12"
                                            BorderBrush="#2A2A35" BorderThickness="1">
                                        <TextBlock Text="1280 x 720" Foreground="#505060" FontSize="8"/>
                                    </Border>
                                </Grid>
                                <Border Grid.Row="1" Margin="10,0" CornerRadius="10"
                                        Background="#080810" BorderBrush="#1A1A24" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <StackPanel x:Name="EmptyBackground" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="+" FontSize="20" Foreground="#252530" HorizontalAlignment="Center" FontWeight="Light"/>
                                            <TextBlock Text="Arrastra o clic" Foreground="#303040" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Image x:Name="PreviewBackground" Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Margin="4" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="2" Margin="10,4,10,8">
                                    <TextBlock x:Name="EstadoBackground" Text="Sin imagen" Foreground="#404050" FontSize="8" VerticalAlignment="Center"/>
                                    <Button x:Name="QuitarBackground" Content="Quitar" FontSize="12"
                                            HorizontalAlignment="Right" Height="16" Padding="6,0"
                                            Visibility="Collapsed" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Foreground="#505060"
                                            Tag="background" Click="BtnQuitar_Click"/>
                                </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ══ EMUMMC ══ -->
                        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" x:Name="SlotEmummc" Tag="emummc"
                                Style="{StaticResource EstiloSlotHekate}"
                                AllowDrop="True" Drop="Slot_Drop" DragOver="Slot_DragOver"
                                DragLeave="Slot_DragLeave" MouseLeftButtonDown="Slot_Click">
                            <Grid ClipToBounds="True">
                                <Ellipse Fill="#1ABD00FF" Width="160" Height="120"
                                         Margin="-30,-25,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Ellipse.Effect><BlurEffect Radius="40"/></Ellipse.Effect>
                                </Ellipse>
                                <Grid>
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="150"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Margin="10,8,10,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ICONO EMUMMC" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                <Border Background="#15BD00FF" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Launch" Foreground="#BD00FF" FontSize="7" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="emummc.bmp" Foreground="#00D2FF" FontSize="8" FontWeight="Bold" Margin="0,0,6,0"/>
                                            <TextBlock Text="/bootloader/res/" Foreground="#505060" FontSize="8"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="5" Padding="6,2" Background="#0D0D12"
                                            BorderBrush="#2A2A35" BorderThickness="1">
                                        <TextBlock Text="256 x 256" Foreground="#505060" FontSize="8"/>
                                    </Border>
                                </Grid>
                                <Border Grid.Row="1" Margin="10,0" CornerRadius="10"
                                        Background="#080810" BorderBrush="#1A1A24" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <StackPanel x:Name="EmptyEmummc" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="+" FontSize="20" Foreground="#252530" HorizontalAlignment="Center" FontWeight="Light"/>
                                            <TextBlock Text="Arrastra o clic" Foreground="#303040" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Image x:Name="PreviewEmummc" Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Margin="4" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="2" Margin="10,4,10,8">
                                    <TextBlock x:Name="EstadoEmummc" Text="Sin imagen" Foreground="#404050" FontSize="8" VerticalAlignment="Center"/>
                                    <Button x:Name="QuitarEmummc" Content="Quitar" FontSize="12"
                                            HorizontalAlignment="Right" Height="16" Padding="6,0"
                                            Visibility="Collapsed" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Foreground="#505060"
                                            Tag="emummc" Click="BtnQuitar_Click"/>
                                </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ══ STOCK ══ -->
                        <Border Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="2" x:Name="SlotStock" Tag="stock"
                                Style="{StaticResource EstiloSlotHekate}"
                                AllowDrop="True" Drop="Slot_Drop" DragOver="Slot_DragOver"
                                DragLeave="Slot_DragLeave" MouseLeftButtonDown="Slot_Click">
                            <Grid ClipToBounds="True">
                                <Ellipse Fill="#1AFF5500" Width="160" Height="120"
                                         Margin="-30,-25,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Ellipse.Effect><BlurEffect Radius="40"/></Ellipse.Effect>
                                </Ellipse>
                                <Grid>
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="150"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Margin="10,8,10,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ICONO STOCK" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                <Border Background="#15BD00FF" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Launch" Foreground="#BD00FF" FontSize="7" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="stock.bmp" Foreground="#00D2FF" FontSize="8" FontWeight="Bold" Margin="0,0,6,0"/>
                                            <TextBlock Text="/bootloader/res/" Foreground="#505060" FontSize="8"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="5" Padding="6,2" Background="#0D0D12"
                                            BorderBrush="#2A2A35" BorderThickness="1">
                                        <TextBlock Text="256 x 256" Foreground="#505060" FontSize="8"/>
                                    </Border>
                                </Grid>
                                <Border Grid.Row="1" Margin="10,0" CornerRadius="10"
                                        Background="#080810" BorderBrush="#1A1A24" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <StackPanel x:Name="EmptyStock" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="+" FontSize="20" Foreground="#252530" HorizontalAlignment="Center" FontWeight="Light"/>
                                            <TextBlock Text="Arrastra o clic" Foreground="#303040" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Image x:Name="PreviewStock" Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Margin="4" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="2" Margin="10,4,10,8">
                                    <TextBlock x:Name="EstadoStock" Text="Sin imagen" Foreground="#404050" FontSize="8" VerticalAlignment="Center"/>
                                    <Button x:Name="QuitarStock" Content="Quitar" FontSize="12"
                                            HorizontalAlignment="Right" Height="16" Padding="6,0"
                                            Visibility="Collapsed" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Foreground="#505060"
                                            Tag="stock" Click="BtnQuitar_Click"/>
                                </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ══ SYSNAND ══ -->
                        <Border Grid.Column="5" Grid.ColumnSpan="2" Grid.Row="2" x:Name="SlotSysnand" Tag="sysnand"
                                Style="{StaticResource EstiloSlotHekate}"
                                AllowDrop="True" Drop="Slot_Drop" DragOver="Slot_DragOver"
                                DragLeave="Slot_DragLeave" MouseLeftButtonDown="Slot_Click">
                            <Grid ClipToBounds="True">
                                <Ellipse Fill="#1A00D2FF" Width="160" Height="120"
                                         Margin="-30,-25,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Ellipse.Effect><BlurEffect Radius="40"/></Ellipse.Effect>
                                </Ellipse>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="150"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Margin="10,8,10,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ICONO SYSNAND" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                <Border Background="#15BD00FF" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Launch" Foreground="#BD00FF" FontSize="7" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="sysnand.bmp" Foreground="#00D2FF" FontSize="8" FontWeight="Bold" Margin="0,0,6,0"/>
                                                <TextBlock Text="/bootloader/res/" Foreground="#505060" FontSize="8"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                CornerRadius="5" Padding="6,2" Background="#0D0D12"
                                                BorderBrush="#2A2A35" BorderThickness="1">
                                            <TextBlock Text="256 x 256" Foreground="#505060" FontSize="8"/>
                                        </Border>
                                    </Grid>
                                    <Border Grid.Row="1" Margin="10,0" CornerRadius="10"
                                            Background="#080810" BorderBrush="#1A1A24" BorderThickness="1" ClipToBounds="True">
                                        <Grid>
                                            <StackPanel x:Name="EmptySysnand" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="+" FontSize="20" Foreground="#252530" HorizontalAlignment="Center" FontWeight="Light"/>
                                                <TextBlock Text="Arrastra o clic" Foreground="#303040" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Image x:Name="PreviewSysnand" Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Margin="4" Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="2" Margin="10,4,10,8">
                                        <TextBlock x:Name="EstadoSysnand" Text="Sin imagen" Foreground="#404050" FontSize="8" VerticalAlignment="Center"/>
                                        <Button x:Name="QuitarSysnand" Content="Quitar" FontSize="12"
                                                HorizontalAlignment="Right" Height="16" Padding="6,0"
                                                Visibility="Collapsed" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" Foreground="#505060"
                                                Tag="sysnand" Click="BtnQuitar_Click"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </ScrollViewer>

                <!-- ═══ Columna derecha: panel NYX ═══ -->
                <Border Grid.Column="1"
                        CornerRadius="20" Background="#0F0F15"
                        BorderBrush="#2A2A35" BorderThickness="2"
                        Margin="0,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="Black" Opacity="0.55"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,15">

                            <!-- Header NYX -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <Border Background="#15BD00FF" CornerRadius="5" Padding="7,2" Margin="0,0,8,0">
                                    <TextBlock Text="HEKATE NYX" Foreground="#BD00FF" FontSize="9" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="TEMA DE COLORES" Foreground="White"
                                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- ── ACENTO ── -->
                            <TextBlock Text="COLOR DE ICONOS" Foreground="#505060"
                                       FontSize="8" FontWeight="Bold" Margin="0,0,0,8"/>

                            <!-- Presets themecolor: generados en code-behind desde ConfiguracionUI -->
                            <WrapPanel x:Name="PanelPresetsAcento" Margin="0,0,0,10"/>

                            <!-- Color seleccionado: swatch + nombre (sin detalles técnicos) -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="MuestraAcento" Grid.Column="0"
                                        Width="26" Height="26" CornerRadius="6"
                                        Background="#FFFFFF" BorderBrush="#2A2A35" BorderThickness="1"/>
                                <TextBlock x:Name="TxtNombreAcento" Grid.Column="1"
                                           Text="—" Foreground="#707080" FontSize="9"
                                           VerticalAlignment="Center" Margin="8,0"/>
                                <!-- TxtPreviewThemecolor: oculto, usado solo para el bloque ini -->
                                <TextBlock x:Name="TxtPreviewThemecolor" Visibility="Collapsed"
                                           Text="themecolor=0"/>
                                <TextBlock x:Name="TxtPreviewThemecolorIni" Visibility="Collapsed"
                                           Text="themecolor=0"/>
                            </Grid>

                            <!-- Separador -->
                            <Rectangle Height="1" Fill="#1A1A28" Margin="0,0,0,14"/>

                            <!-- ── FONDO ── -->
                            <TextBlock Text="COLOR DE FONDO" Foreground="#505060"
                                       FontSize="8" FontWeight="Bold" Margin="0,0,0,8"/>

                            <!-- Presets themebg: generados en code-behind desde ConfiguracionUI -->
                            <WrapPanel x:Name="PanelPresetsFondo" Margin="0,0,0,10"/>

                            <!-- Color de fondo seleccionado: swatch + nombre -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="MuestraFondo" Grid.Column="0"
                                        Width="26" Height="26" CornerRadius="6"
                                        Background="#0B0B0B" BorderBrush="#2A2A35" BorderThickness="1"/>
                                <TextBlock x:Name="TxtNombreFondo" Grid.Column="1"
                                           Text="—" Foreground="#707080" FontSize="9"
                                           VerticalAlignment="Center" Margin="8,0"/>
                                <!-- TxtPreviewThemebg: oculto, usado solo para el bloque ini -->
                                <TextBlock x:Name="TxtPreviewThemebg" Visibility="Collapsed"
                                           Text="themebg=0b0b0b"/>
                                <TextBlock x:Name="TxtPreviewThemebgIni" Visibility="Collapsed"
                                           Text="themebg=0b0b0b"/>
                            </Grid>

                            <!-- Separador -->
                            <Rectangle Height="1" Fill="#1A1A28" Margin="0,0,0,14"/>

                      

                            <!-- Boton guardar NYX (independiente de imagenes) -->
                            <Button x:Name="BtnGuardarNyx"
                                    Height="38" Width="228"
                                    HorizontalAlignment="Stretch"
                                    Click="BtnGuardarNyx_Click"
                                    Style="{StaticResource EstiloBotonAccionBase}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="GUARDAR TEMA NYX" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="TxtLogNyx" Text="" Foreground="#40C057"
                                       FontSize="9" Margin="0,6,0,0"
                                       TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── Barra inferior ── -->
            <Border Grid.Row="2" Background="#0F0F16" BorderBrush="#2A2A35"
                    BorderThickness="0,1,0,0" Padding="14,10" CornerRadius="0,0,15,15">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtResumen" Foreground="#505060" FontSize="10"
                                   Text="Carga al menos una imagen para copiar a la SD"/>
                        <TextBlock x:Name="TxtLog" Foreground="#40C057" FontSize="9"
                                   Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button x:Name="BtnCopiarSD"
                            HorizontalAlignment="Right"
                            Width="200" Height="40"
                            IsEnabled="False"
                            Click="BtnCopiarSD_Click"
                            Style="{StaticResource EstiloBotonAccionBase}">
                        <TextBlock Text="COPIAR IMAGENES A SD" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
