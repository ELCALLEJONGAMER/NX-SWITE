<UserControl x:Class="NX_Suite.UI.Controles.PanelDerecho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#15151C" CornerRadius="0,15,15,0">
        <StackPanel Margin="15,20">
            <TextBlock Text="MICRO SD" Foreground="#707080" FontSize="10" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
            <TextBlock Text="UNIDAD EXTRAÍBLE" Foreground="#707080" FontSize="9" FontWeight="Bold"/>

            <ComboBox x:Name="ComboDrives" Style="{StaticResource EstiloComboOscuro}" Margin="0,5,0,15" Height="28"/>

            <TextBlock Text="TAMAÑO TOTAL" Foreground="#707080" FontSize="9" FontWeight="Bold"/>
            <TextBlock x:Name="TxtTotalSize" Text="0 GB" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,15"/>

            <TextBlock Text="SISTEMA DE ARCHIVOS" Foreground="#707080" FontSize="9" FontWeight="Bold"/>
            <TextBlock x:Name="TxtFileSystem" Text="--" Foreground="#00D2FF" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,15"/>

            <TextBlock Text="VERSION ATMOSPHERE" Foreground="#707080" FontSize="9" FontWeight="Bold"/>
            <TextBlock x:Name="TxtAtmosVer" Text="--" Foreground="#BD00FF" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,15"/>

            <TextBlock Text="SERIAL NINTENDO SWITCH" Foreground="#707080" FontSize="9" FontWeight="Bold"/>
            <TextBlock x:Name="TxtSDSerial" Text="ID: --" Foreground="White" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,15"/>
        </StackPanel>
    </Border>
</UserControl>