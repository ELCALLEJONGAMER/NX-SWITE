<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="NX_Suite.UI.Controles.VistaPersonalizacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cfg="clr-namespace:NX_Suite.Core.Configuracion"
             xmlns:models="clr-namespace:NX_Suite.Models">

    <UserControl.Resources>
        <Style x:Key="EstiloBotonPersonalizacionHekate"
               TargetType="Button"
               BasedOn="{StaticResource EstiloBotonAccionBase}">
            <Setter Property="Width" Value="390"/>
            <Setter Property="Height" Value="66"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="TEMAS DE INICIO"
                       Foreground="#00D2FF" FontSize="11" FontWeight="Bold" Opacity="0.85"/>
            <TextBlock Text="Temas ensamblados con imagen Hekate y config NYX lista para aplicar"
                       Foreground="#707080" FontSize="10" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Catalogo de temas -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ListaTemas">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:TemaConfig}">
                        <Border Width="210" Height="200"
                                Margin="0,0,12,12"
                                CornerRadius="14"
                                BorderThickness="2"
                                Background="#12121A"
                                Cursor="Hand"
                                MouseLeftButtonDown="TarjetaTema_Click"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#2A2A35"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Aplicado}" Value="True">
                                            <Setter Property="BorderBrush" Value="#00D2FF"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#505060"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Preview -->
                                <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                        ClipToBounds="True" Background="#0D0D12">
                                    <Image Source="{Binding PreviewUrl}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Badge ACTIVO -->
                                <Border Grid.Row="0" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Margin="0,7,7,0"
                                        CornerRadius="5" Padding="7,2"
                                        Background="#CC00D2FF">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Aplicado}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="ACTIVO" FontSize="8"
                                               FontWeight="Bold" Foreground="Black"/>
                                </Border>

                                <!-- Badge OFICIAL -->
                                <Border Grid.Row="0" HorizontalAlignment="Left"
                                        VerticalAlignment="Top" Margin="7,7,0,0"
                                        CornerRadius="5" Padding="7,2"
                                        Background="#CCBD00FF">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsOficial}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="OFICIAL" FontSize="8"
                                               FontWeight="Bold" Foreground="White"/>
                                </Border>

                                <!-- Info + badges de contenido -->
                                <Grid Grid.Row="1" Margin="10,8,10,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Nombre}"
                                               Foreground="White" FontSize="12"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Autor}"
                                               Foreground="#707080" FontSize="9"
                                               Margin="0,1,0,5"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Indicadores de contenido -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <!-- Hekate image badge -->
                                        <Border CornerRadius="4" Padding="5,2" Margin="0,0,4,0"
                                                Background="#1500D2FF">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HekateImagenUrl}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Hekate IMG" FontSize="8"
                                                       Foreground="#00D2FF" FontWeight="Bold"/>
                                        </Border>
                                        <!-- NYX badge -->
                                        <Border CornerRadius="4" Padding="5,2"
                                                Background="#15BD00FF">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NyxColorAcento}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="NYX" FontSize="8"
                                                       Foreground="#BD00FF" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Boton inferior para abrir personalizacion manual -->
        <Border Grid.Row="2"
                BorderBrush="#2A2A35" BorderThickness="0,1,0,0"
                Padding="0,18,0,2" Margin="0,10,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="PERSONALIZACIÓN MANUAL"
                           Foreground="#00D2FF"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Opacity="0.9"/>
                <TextBlock Text="Crea tu propio tema Hekate + NYX"
                           Foreground="#707080"
                           FontSize="10"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,3,0,12"/>

                <Button Style="{StaticResource EstiloBotonPersonalizacionHekate}"
                        Cursor="Hand"
                        ToolTip="Abrir creador de temas para Hekate"
                        
                        Click="BtnAbrirPersonalizacion_Click"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Image Width="34" Height="34"
                               Margin="0,0,12,0"
                               Stretch="Uniform"
                               Opacity="0.95"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoPaintUrl, Converter={StaticResource IconoCacheConverter}}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CREAR TEMA PARA HEKATE"
                                       FontSize="13"
                                       FontWeight="Black"
                                       Foreground="White"/>
                            <TextBlock Text="Imagen de arranque, colores y configuración NYX"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="#707080"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
