<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="NX_Suite.UI.Controles.VistaPersonalizacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:NX_Suite.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="TEMAS DE INICIO"
                       Foreground="#00D2FF" FontSize="11" FontWeight="Bold" Opacity="0.85"/>
            <TextBlock Text="Temas ensamblados con imagen Hekate y config NYX lista para aplicar"
                       Foreground="#707080" FontSize="10" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Catalogo de temas -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ListaTemas">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:TemaConfig}">
                        <Border Width="210" Height="200"
                                Margin="0,0,12,12"
                                CornerRadius="14"
                                BorderThickness="2"
                                Background="#12121A"
                                Cursor="Hand"
                                MouseLeftButtonDown="TarjetaTema_Click"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#2A2A35"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Aplicado}" Value="True">
                                            <Setter Property="BorderBrush" Value="#00D2FF"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#505060"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Preview -->
                                <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                        ClipToBounds="True" Background="#0D0D12">
                                    <Image Source="{Binding PreviewUrl}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Badge ACTIVO -->
                                <Border Grid.Row="0" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Margin="0,7,7,0"
                                        CornerRadius="5" Padding="7,2"
                                        Background="#CC00D2FF">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Aplicado}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="ACTIVO" FontSize="8"
                                               FontWeight="Bold" Foreground="Black"/>
                                </Border>

                                <!-- Badge OFICIAL -->
                                <Border Grid.Row="0" HorizontalAlignment="Left"
                                        VerticalAlignment="Top" Margin="7,7,0,0"
                                        CornerRadius="5" Padding="7,2"
                                        Background="#CCBD00FF">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsOficial}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="OFICIAL" FontSize="8"
                                               FontWeight="Bold" Foreground="White"/>
                                </Border>

                                <!-- Info + badges de contenido -->
                                <Grid Grid.Row="1" Margin="10,8,10,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Nombre}"
                                               Foreground="White" FontSize="12"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Autor}"
                                               Foreground="#707080" FontSize="9"
                                               Margin="0,1,0,5"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Indicadores de contenido -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <!-- Hekate image badge -->
                                        <Border CornerRadius="4" Padding="5,2" Margin="0,0,4,0"
                                                Background="#1500D2FF">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HekateImagenUrl}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Hekate IMG" FontSize="8"
                                                       Foreground="#00D2FF" FontWeight="Bold"/>
                                        </Border>
                                        <!-- NYX badge -->
                                        <Border CornerRadius="4" Padding="5,2"
                                                Background="#15BD00FF">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NyxColorAcento}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="NYX" FontSize="8"
                                                       Foreground="#BD00FF" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Boton inferior para abrir personalizacion manual -->
        <Border Grid.Row="2"
                BorderBrush="#2A2A35" BorderThickness="0,1,0,0"
                Padding="0,14,0,0" Margin="0,8,0,0">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PERSONALIZACION MANUAL"
                               Foreground="#505060" FontSize="9" FontWeight="Bold"/>
                    <TextBlock Text="Elige tus propias imagenes Hekate y colores NYX"
                               Foreground="#404050" FontSize="9" Margin="0,2,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Width="200" Height="38"
                        Content="ABRIR PERSONALIZACION"
                        Cursor="Hand"
                        Click="BtnAbrirPersonalizacion_Click"
                        Style="{StaticResource EstiloBotonAccionBase}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
