<UserControl x:Class="NX_Suite.UI.Controles.PanelIzquierdo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#15151C" CornerRadius="0,0,0,15">
        <Grid>
            <StackPanel Margin="0,0">
                <StackPanel x:Name="CabeceraPrograma" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Button x:Name="BtnLogoPrograma"
                            Width="130"
                            Height="130"
                            Padding="0"
                            Margin="0,0,0,0"
                            ToolTip="Volver al inicio"
                            Style="{StaticResource EstiloBotonTopBar}"
                            Click="BtnLogoPrograma_Click">
                        <Image x:Name="ImgLogoPrograma"
                               Width="130"
                               Height="130"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding LogoUrl, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IconoCacheConverter}}"/>
                    </Button>

                    <TextBlock x:Name="TxtNombrePrograma"
                               Text="{Binding NombrePrograma, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="#00D2FF"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    <TextBlock x:Name="TxtVersionApp"
                               Foreground="#404055"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <ListBox x:Name="ListaMundos"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource EstiloItemMundoGamer}"
                         ItemTemplate="{StaticResource PlantillaItemMundo}">
                </ListBox>
            </StackPanel>

            <Button VerticalAlignment="Bottom" Margin="0" Style="{StaticResource EstiloBotonCerrar}" Click="BtnClose_Click">
                <StackPanel Orientation="Horizontal">
                    
                    
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>