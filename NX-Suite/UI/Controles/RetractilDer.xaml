<UserControl x:Class="NX_Suite.UI.Controles.RetractilDer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="RielGris" Background="#2A2A35" CornerRadius="30,0,0,30" Width="10" Cursor="Hand">
        <Grid>
            <StackPanel x:Name="Pestanita" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse Width="4" Height="4" Fill="#707080" Margin="0,2"/>
                <Ellipse Width="4" Height="4" Fill="#707080" Margin="0,2"/>
                <Ellipse Width="4" Height="4" Fill="#707080" Margin="0,2"/>
            </StackPanel>

            <Grid x:Name="ContenedorArsenal" Opacity="0" IsHitTestVisible="False">
                <StackPanel Margin="15,20">
                    <TextBlock Text="ARSENAL SD" Foreground="#BD00FF" FontSize="14" FontWeight="Bold" Margin="0,10,0,30" HorizontalAlignment="Center"/>
                    <Button Content="ACTUALIZAR TODO" Style="{StaticResource EstiloBotonMenu}" Height="35" Margin="0,5"/>
                    <Button x:Name="BtnFormatFAT32"
                            Content="FORMAT FAT32"
                            Style="{StaticResource EstiloBotonMenu}"
                            Height="35" Margin="0,5"
                            Click="BtnFormatFAT32_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>