<UserControl x:Class="NX_Suite.UI.Controles.VistaAsistida"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NX_Suite.UI.Controles">

    <UserControl.Resources>

        <!-- Tarjeta rellena (módulo ya seleccionado en complementos) -->
        <DataTemplate x:Key="PlantillaSlotRelleno">
            <Border Width="140" Height="170" Margin="0,0,10,10"
                    CornerRadius="12"
                    Background="{StaticResource FondoPaneles}"
                    BorderBrush="{StaticResource AcentoRojo}"
                    BorderThickness="2"
                    Cursor="Hand">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="38"/>
                    </Grid.RowDefinitions>
                    <Image Source="{Binding IconoUrl}" Stretch="UniformToFill"
                           Margin="10" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Grid.Row="1" Text="{Binding Nombre}"
                               Foreground="{StaticResource TextoPrimario}"
                               FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="6,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Tarjeta vacía "+" (slot para agregar en complementos) -->
        <DataTemplate x:Key="PlantillaSlotVacio">
            <Button Width="140" Height="170" Margin="0,0,10,10"
                    Tag="{Binding}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BorderVacio"
                                CornerRadius="12"
                                Background="{StaticResource FondoPaneles}"
                                BorderBrush="{StaticResource BordeGeneral}"
                                BorderThickness="1.5">
                            <TextBlock Text="+"
                                       Foreground="{StaticResource TextoSecundario}"
                                       FontSize="36" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderVacio" Property="BorderBrush"
                                        Value="{StaticResource AcentoCian}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- Selector que enruta entre PlantillaSlotRelleno y PlantillaSlotVacio -->
        <local:SlotTemplateSelector x:Key="SlotSelectorTemplate"
                                    ModuloTemplate="{StaticResource PlantillaSlotRelleno}"
                                    VacioTemplate="{StaticResource PlantillaSlotVacio}"/>

        <!-- Botón de texto limpio (Volver, ↺) -->
        <Style x:Key="EstiloBtnTexto" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextoPrimario}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle de modo Libre / Forzado -->
        <Style x:Key="EstiloToggleModo" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RaizBorder"
                                CornerRadius="8"
                                Background="{StaticResource FondoPaneles}"
                                BorderBrush="{StaticResource BordeGeneral}"
                                BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RaizBorder" Property="Background" Value="#1A0035"/>
                                <Setter TargetName="RaizBorder" Property="BorderBrush"
                                        Value="{StaticResource AcentoPurpura}"/>
                                <Setter Property="Foreground" Value="{StaticResource AcentoPurpura}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RaizBorder" Property="BorderBrush"
                                        Value="{StaticResource AcentoCian}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>

        <!-- ═══════════════════════════════════════════════
             VISTA A — NÚCLEO: acordeón de slots
             ═══════════════════════════════════════════════ -->
        <Grid x:Name="GridNucleo" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toggle modo (arriba derecha) -->
            <ToggleButton x:Name="SwitchModo"
                          Grid.Row="0"
                          Style="{StaticResource EstiloToggleModo}"
                          Content="MODO LIBRE"
                          HorizontalAlignment="Right"
                          Margin="0,0,0,16"
                          Checked="SwitchModo_Changed"
                          Unchecked="SwitchModo_Changed"/>

            <!-- Lista de slots -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ListaSlots"
                              ButtonBase.Click="SlotBoton_Click">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Margin="0,0,0,12" CornerRadius="12"
                                    Background="{StaticResource FondoPaneles}"
                                    Height="90" Cursor="Hand">
                                <!-- Borde dinámico: gris si vacío, ColorNeon si tiene selección -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource BordeGeneral}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TieneSeleccion}"
                                                         Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="{Binding ColorNeon,
                                                                Converter={StaticResource ColorNeonConverter}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <!-- ESTADO VACÍO: botón cubre toda la tarjeta -->
                                    <Button Tag="{Binding}" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <ContentPresenter/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TieneSeleccion}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}"
                                                       Foreground="#A0A0B0"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="+"
                                                       Foreground="{StaticResource TextoSecundario}"
                                                       FontSize="24" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- ESTADO SELECCIONADO: icono + info + botón cambiar -->
                                    <Grid Margin="20,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TieneSeleccion}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icono del módulo -->
                                        <Border Grid.Column="0"
                                                Width="52" Height="52"
                                                CornerRadius="10"
                                                BorderBrush="{Binding ColorNeon,
                                                              Converter={StaticResource ColorNeonConverter}}"
                                                BorderThickness="1.5"
                                                VerticalAlignment="Center">
                                            <Image Source="{Binding IconoModulo}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>

                                        <!-- Nombre + versión -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="14,0,0,0">
                                            <TextBlock Text="{Binding Nombre}"
                                                       Foreground="{StaticResource TextoSecundario}"
                                                       FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding NombreModulo}"
                                                       Foreground="{Binding ColorNeon,
                                                                    Converter={StaticResource ColorNeonConverter}}"
                                                       FontSize="19" FontWeight="Bold"
                                                       Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding VersionModulo}"
                                                       Foreground="{Binding ColorNeon,
                                                                    Converter={StaticResource ColorNeonConverter}}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Opacity="0.65"/>
                                        </StackPanel>

                                        <!-- Botón cambiar (↺) -->
                                        <Button Grid.Column="2"
                                                Tag="{Binding}"
                                                Style="{StaticResource EstiloBtnTexto}"
                                                Content="↺"
                                                FontSize="22"
                                                Padding="8"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Siguiente -->
            <Button x:Name="BtnSiguienteNucleo"
                    Grid.Row="2"
                    Content="Siguiente"
                    Style="{StaticResource EstiloBotonInstalar}"
                    HorizontalAlignment="Right"
                    Width="180"
                    Margin="0,12,0,0"
                    Visibility="Collapsed"
                    Click="BtnSiguienteNucleo_Click"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════
             VISTA B — SELECTOR DE MÓDULOS
             ═══════════════════════════════════════════════ -->
        <Grid x:Name="GridSelector" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&lt; Volver"
                        Style="{StaticResource EstiloBtnTexto}"
                        FontSize="13" FontWeight="SemiBold"
                        Padding="0" Margin="0,0,20,0"
                        VerticalAlignment="Center"
                        Click="BtnVolverDesdeSelector_Click"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTituloSelector"
                               Foreground="{StaticResource TextoPrimario}"
                               FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtSubtituloSelector"
                               Foreground="{StaticResource TextoSecundario}"
                               FontSize="11" FontWeight="SemiBold"
                               Opacity="0.85"/>
                </StackPanel>
            </Grid>

            <!-- Buscador -->
            <Border Grid.Row="1" Margin="0,0,0,16"
                    Background="{StaticResource FondoPaneles}"
                    BorderBrush="{StaticResource BordeGeneral}"
                    BorderThickness="1" CornerRadius="10">
                <TextBox x:Name="TxtBuscador"
                         Background="Transparent"
                         Foreground="{StaticResource TextoPrimario}"
                         CaretBrush="{StaticResource AcentoCian}"
                         BorderThickness="0"
                         FontSize="14"
                         Padding="14,10"
                         TextChanged="TxtBuscador_TextChanged"/>
            </Border>

            <!-- Tarjetas de módulos -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ListaModulosSelector"
                              ItemTemplate="{StaticResource PlantillaModuloGamer}"
                              MouseLeftButtonDown="SelectorModulo_Click">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════════════════════════════
             VISTA C — COMPLEMENTOS DEL MÓDULO
             ═══════════════════════════════════════════════ -->
        <Grid x:Name="GridComplementos" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecera con nombre del módulo y botón volver -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&lt; Volver"
                        Style="{StaticResource EstiloBtnTexto}"
                        FontSize="13" FontWeight="SemiBold"
                        Padding="0" Margin="0,0,20,0"
                        VerticalAlignment="Center"
                        Click="BtnVolverDesdeComplementos_Click"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTituloComplementos"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource AcentoCian}"/>
                    <TextBlock x:Name="TxtVersionComplementos"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource AcentoPurpura}"/>
                </StackPanel>
            </Grid>

            <!-- Subcategorías con sus slots -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ListaSubcategorias"
                              ButtonBase.Click="ComplementoSlotClick">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,28">

                                <!-- Título de sección: "> Payloads" -->
                                <TextBlock Foreground="{StaticResource TextoSecundario}"
                                           FontSize="13" FontWeight="Bold"
                                           Margin="0,0,0,10">
                                    <Run Text="&gt; "/>
                                    <Run Text="{Binding Nombre}"/>
                                </TextBlock>

                                <!-- Slots: módulos seleccionados + slot vacío "+" -->
                                <ItemsControl ItemsSource="{Binding SlotsVisibles}"
                                              ItemTemplateSelector="{StaticResource SlotSelectorTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Siguiente -->
            <Button x:Name="BtnSiguienteComplementos"
                    Grid.Row="2"
                    Content="Siguiente"
                    Style="{StaticResource EstiloBotonInstalar}"
                    HorizontalAlignment="Right"
                    Width="180"
                    Margin="0,12,0,0"
                    Click="BtnSiguienteComplementos_Click"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════
             VISTA D — RESUMEN FINAL
             ═══════════════════════════════════════════════ -->
        <Grid x:Name="GridResumen" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tarjetas resumen -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ListaResumen">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" CornerRadius="12"
                                    Background="{StaticResource FondoPaneles}"
                                    BorderBrush="{Binding ColorNeon,
                                                  Converter={StaticResource ColorNeonConverter}}"
                                    BorderThickness="2"
                                    Height="90">
                                <Grid Margin="20,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="52" Height="52"
                                            CornerRadius="10"
                                            BorderBrush="{Binding ColorNeon,
                                                          Converter={StaticResource ColorNeonConverter}}"
                                            BorderThickness="1.5"
                                            VerticalAlignment="Center">
                                        <Image Source="{Binding IconoModulo}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Margin="15,0,0,0">
                                        <TextBlock Text="{Binding NombreModulo}"
                                                   Foreground="{Binding ColorNeon,
                                                                Converter={StaticResource ColorNeonConverter}}"
                                                   FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding VersionModulo}"
                                                   Foreground="{Binding ColorNeon,
                                                                Converter={StaticResource ColorNeonConverter}}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Opacity="0.7"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Instalar -->
            <Button x:Name="BtnInstalarAsistido"
                    Grid.Row="1"
                    Content="INSTALAR"
                    Style="{StaticResource EstiloBotonInstalar}"
                    HorizontalAlignment="Right"
                    Width="200"
                    Margin="0,12,0,0"
                    Click="BtnInstalarAsistido_Click"/>
        </Grid>

    </Grid>
</UserControl>