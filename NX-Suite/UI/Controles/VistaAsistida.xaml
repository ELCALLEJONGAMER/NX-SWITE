<UserControl x:Class="NX_Suite.UI.Controles.VistaAsistida"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NX_Suite.UI.Controles"
             xmlns:core="clr-namespace:NX_Suite.Core">

    <UserControl.Resources>

        <!-- Fila compacta de complemento ya seleccionado (slot relleno) -->
        <DataTemplate x:Key="PlantillaSlotRelleno">
            <Border x:Name="BordSlotRelleno" Height="52" Margin="0,0,0,6" CornerRadius="10"
                    Background="{StaticResource FondoPaneles}"
                    BorderBrush="{StaticResource AcentoVerde}"
                    BorderThickness="1.5"
                    RenderTransformOrigin="0.5,0.5"
                    MouseEnter="Slot_HoverSonido">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" VerticalAlignment="Center">
                        <Image Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding Nombre}"
                               Foreground="{StaticResource TextoPrimario}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="2" Tag="{Binding}"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" VerticalAlignment="Center"
                            Click="BtnEliminarComplemento_Click">
                        <TextBlock Text="&#x2715;" FontSize="10"
                                   Foreground="{StaticResource TextoSecundario}" Opacity="0.7"/>
                    </Button>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="BordSlotRelleno"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1.02" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetName="BordSlotRelleno"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1.02" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="BordSlotRelleno"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetName="BordSlotRelleno"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Slot vacío: fila compacta de agregar -->
        <DataTemplate x:Key="PlantillaSlotVacio">
            <Button Tag="{Binding}" Cursor="Hand" Margin="0,0,0,6"
                    MouseEnter="Slot_HoverSonido">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bv" Height="44" CornerRadius="10"
                                Background="{StaticResource FondoPaneles}"
                                BorderBrush="{StaticResource BordeGeneral}"
                                BorderThickness="1.5"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#x2B;" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Agregar" FontSize="11"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bv" Property="BorderBrush" Value="{StaticResource AcentoCian}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bv"
                                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                             To="1.02" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="Bv"
                                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                             To="1.02" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bv"
                                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                             To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="Bv"
                                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                             To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <local:SlotTemplateSelector x:Key="SlotSelectorTemplate"
                                    ModuloTemplate="{StaticResource PlantillaSlotRelleno}"
                                    VacioTemplate="{StaticResource PlantillaSlotVacio}"/>

        <!-- Card cuadrada de módulo seleccionado en sección Hekate (con X para quitar) -->
        <DataTemplate x:Key="PlantillaCardSeleccionadoHekate">
            <Grid MouseEnter="Slot_HoverSonido">
                <Border x:Name="CuerpoCard"
                        Width="155" Height="150"
                        Margin="6"
                        CornerRadius="16"
                        Background="#0F0F15"
                        BorderThickness="1.5"
                        BorderBrush="{StaticResource AcentoVerde}"
                        Cursor="Hand"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect x:Name="SombraCard" BlurRadius="10" ShadowDepth="0" Color="#40C057" Opacity="0.25"/>
                    </Border.Effect>
                    <Grid ClipToBounds="True" Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                        </Grid.RowDefinitions>
                        <!-- Fila 0: X quitar (derecha) -->
                        <Button Grid.Row="0" Tag="{Binding}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#15FFFFFF" BorderThickness="0"
                                Width="18" Height="18" Cursor="Hand"
                                Click="BtnQuitarDeSeccion_Click">
                            <TextBlock Text="&#x2715;" FontSize="8"
                                       Foreground="{StaticResource TextoSecundario}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <!-- Fila 1: Icono -->
                        <Image Grid.Row="1"
                               Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                               Stretch="Uniform" MaxHeight="52"
                               Margin="0,2,0,2"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <!-- Fila 2: Nombre -->
                        <TextBlock Grid.Row="2"
                                   Text="{Binding Nombre}"
                                   Foreground="White" FontSize="11" FontWeight="ExtraBold"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   MaxHeight="28" TextTrimming="CharacterEllipsis"/>
                        <!-- Fila 3: Versión -->
                        <TextBlock Grid.Row="3"
                                   Text="{Binding Versiones[0].Version, FallbackValue=''}"
                                   Foreground="#50FFFFFF" FontSize="9" FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCard"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1.04" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCard"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1.04" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="SombraCard"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="22" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCard"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCard"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="SombraCard"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="10" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Card cuadrada + Agregar (placeholder al final de cada sección Hekate) -->
        <DataTemplate x:Key="PlantillaCardAgregarHekate">
            <Button Tag="{Binding Seccion}" Cursor="Hand"
                    Background="Transparent" BorderThickness="0"
                    Click="BtnAgregarHekateSeccion_Click"
                    MouseEnter="Slot_HoverSonido">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Button.Template>
                <Border x:Name="CardAgregar"
                        Width="155" Height="150"
                        Margin="6"
                        CornerRadius="16"
                        Background="#0F0F15"
                        BorderThickness="1.5"
                        BorderBrush="{StaticResource BordeGeneral}"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect x:Name="SombraAgregar" BlurRadius="8" ShadowDepth="0" Color="Black" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="+" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextoSecundario}"
                                   HorizontalAlignment="Center" Opacity="0.45"/>
                        <TextBlock Text="Agregar" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoSecundario}"
                                   HorizontalAlignment="Center" Opacity="0.45"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Button>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CardAgregar"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1.04" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CardAgregar"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1.04" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CardAgregar"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CardAgregar"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Selector para las cards de sección Hekate -->
        <local:HekateSeccionCardTemplateSelector x:Key="HekateCardSelector"
            ModuloTemplate="{StaticResource PlantillaCardSeleccionadoHekate}"
            AgregarTemplate="{StaticResource PlantillaCardAgregarHekate}"/>

        <!-- Card cuadrada de módulo seleccionado en complementos de pilar (con X) -->
        <DataTemplate x:Key="PlantillaCardSeleccionadoComplemento">
            <Grid MouseEnter="Slot_HoverSonido">
                <Border x:Name="CuerpoCardComp"
                        Width="155" Height="150"
                        Margin="6"
                        CornerRadius="16"
                        Background="#0F0F15"
                        BorderThickness="1.5"
                        BorderBrush="{StaticResource AcentoVerde}"
                        Cursor="Hand"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect x:Name="SombraCardComp" BlurRadius="10" ShadowDepth="0" Color="#40C057" Opacity="0.25"/>
                    </Border.Effect>
                    <Grid ClipToBounds="True" Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Tag="{Binding}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#15FFFFFF" BorderThickness="0"
                                Width="18" Height="18" Cursor="Hand"
                                Click="BtnEliminarComplemento_Click">
                            <TextBlock Text="&#x2715;" FontSize="8"
                                       Foreground="{StaticResource TextoSecundario}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Image Grid.Row="1"
                               Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                               Stretch="Uniform" MaxHeight="52" Margin="0,2,0,2"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding Nombre}"
                                   Foreground="White" FontSize="11" FontWeight="ExtraBold"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   MaxHeight="28" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="3"
                                   Text="{Binding Versiones[0].Version, FallbackValue=''}"
                                   Foreground="#50FFFFFF" FontSize="9" FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCardComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1.04" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCardComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1.04" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="SombraCardComp"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="22" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCardComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CuerpoCardComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="SombraCardComp"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="10" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Card + Agregar para complementos de pilar (abre overlay multi-selector) -->
        <DataTemplate x:Key="PlantillaCardAgregarComplemento">
            <Button Tag="{Binding Subcategoria}" Cursor="Hand"
                    Background="Transparent" BorderThickness="0"
                    Click="BtnAgregarComplementoCard_Click"
                    MouseEnter="Slot_HoverSonido">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Button.Template>
                <Border x:Name="CardAgregarComp"
                        Width="155" Height="150"
                        Margin="6"
                        CornerRadius="16"
                        Background="#0F0F15"
                        BorderThickness="1.5"
                        BorderBrush="{StaticResource BordeGeneral}"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect x:Name="SombraAgregarComp" BlurRadius="8" ShadowDepth="0" Color="Black" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="+" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextoSecundario}"
                                   HorizontalAlignment="Center" Opacity="0.45"/>
                        <TextBlock Text="Agregar" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoSecundario}"
                                   HorizontalAlignment="Center" Opacity="0.45"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Button>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CardAgregarComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1.04" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CardAgregarComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1.04" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CardAgregarComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                 To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="CardAgregarComp"
                                                 Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                 To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <local:ComplementoCardTemplateSelector x:Key="ComplementoCardSelectorTemplate"
            ModuloTemplate="{StaticResource PlantillaCardSeleccionadoComplemento}"
            AgregarTemplate="{StaticResource PlantillaCardAgregarComplemento}"/>

        <Style x:Key="EstiloBtnTexto" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{StaticResource TextoSecundario}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             INDICADOR DE PASOS (4 círculos: Boot, CFW, FW, Resumen)
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#09090F" Padding="0,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <StackPanel Width="100" HorizontalAlignment="Center">
                    <Border x:Name="CirPaso0" Width="36" Height="36" CornerRadius="18"
                            BorderThickness="2.5" BorderBrush="#30707080"
                            Background="Transparent" HorizontalAlignment="Center">
                        <TextBlock Text="1" FontSize="13" FontWeight="Bold" Foreground="#40FFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtPaso0" Text="Bootloader" FontSize="9.5" FontWeight="Bold"
                               Foreground="#40FFFFFF" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <Rectangle x:Name="LineaPaso0" Width="40" Height="2" Fill="#18707080"
                           VerticalAlignment="Top" Margin="0,17,0,0"/>

                <StackPanel Width="100" HorizontalAlignment="Center">
                    <Border x:Name="CirPaso1" Width="36" Height="36" CornerRadius="18"
                            BorderThickness="2.5" BorderBrush="#30707080"
                            Background="Transparent" HorizontalAlignment="Center">
                        <TextBlock Text="2" FontSize="13" FontWeight="Bold" Foreground="#40FFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtPaso1" Text="CFW" FontSize="9.5" FontWeight="Bold"
                               Foreground="#40FFFFFF" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <Rectangle x:Name="LineaPaso1" Width="40" Height="2" Fill="#18707080"
                           VerticalAlignment="Top" Margin="0,17,0,0"/>

                <StackPanel Width="100" HorizontalAlignment="Center">
                    <Border x:Name="CirPaso2" Width="36" Height="36" CornerRadius="18"
                            BorderThickness="2.5" BorderBrush="#30707080"
                            Background="Transparent" HorizontalAlignment="Center">
                        <TextBlock Text="3" FontSize="13" FontWeight="Bold" Foreground="#40FFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtPaso2" Text="Firmware" FontSize="9.5" FontWeight="Bold"
                               Foreground="#40FFFFFF" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <Rectangle x:Name="LineaPaso2" Width="40" Height="2" Fill="#18707080"
                           VerticalAlignment="Top" Margin="0,17,0,0"/>

                <StackPanel Width="100" HorizontalAlignment="Center">
                    <Border x:Name="CirPaso3" Width="36" Height="36" CornerRadius="18"
                            BorderThickness="2.5" BorderBrush="#30707080"
                            Background="Transparent" HorizontalAlignment="Center">
                        <TextBlock Text="&#x2713;" FontSize="14" FontWeight="Bold" Foreground="#40FFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtPaso3" Text="Resumen" FontSize="9.5" FontWeight="Bold"
                               Foreground="#40FFFFFF" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════
             ÁREA DE CONTENIDO
             ═══════════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.Column="0">

            <!-- ──────────────────────────────────────
                 VISTA PILAR — selección de pilar (Boot/CFW/FW)
                 ────────────────────────────────────── -->
            <Grid x:Name="GridPaso" Visibility="Visible">
                <Grid Margin="28,20,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border x:Name="BadgeObligatorio" CornerRadius="6" Padding="10,4"
                                    Background="#18A855F7" BorderBrush="#30A855F7" BorderThickness="1">
                                <TextBlock Text="OBLIGATORIO" FontSize="9" FontWeight="Bold" Foreground="#A855F7"/>
                            </Border>
                            <Border x:Name="BadgeOpcional" CornerRadius="6" Padding="10,4"
                                    Background="#14707080" BorderBrush="#20707080" BorderThickness="1"
                                    Visibility="Collapsed">
                                <TextBlock Text="OPCIONAL — puedes saltarte este paso"
                                           FontSize="9" FontWeight="Bold" Foreground="#707080"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="TxtTituloPaso" FontSize="30" FontWeight="Black"
                                   Foreground="{StaticResource AcentoCian}"/>
                        <TextBlock x:Name="TxtDescripcionPaso" FontSize="13"
                                   Foreground="{StaticResource TextoSecundario}"
                                   Opacity="0.85" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="640"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Button x:Name="BtnPaginaAnterior" VerticalAlignment="Center" HorizontalAlignment="Left"
                                    Style="{StaticResource EstiloBtnTexto}" Padding="4" Margin="-10,0,0,0"
                                    Visibility="Collapsed" Click="BtnPaginaAnterior_Click">
                                <Image Width="32" Height="32" Stretch="Uniform" Opacity="0.7"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoPaginaAnteriorUrl}"/>
                            </Button>

                            <ItemsControl x:Name="ListaModulosPaso"
                                          ItemTemplate="{StaticResource PlantillaTarjetaAsistida}"
                                          MouseLeftButtonDown="PasoModulo_Click">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <Button x:Name="BtnPaginaSiguiente" VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Style="{StaticResource EstiloBtnTexto}" Padding="4" Margin="0,0,-10,0"
                                    Visibility="Collapsed" Click="BtnPaginaSiguiente_Click">
                                <Image Width="32" Height="32" Stretch="Uniform" Opacity="0.7"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoPaginaSiguienteUrl}"/>
                            </Button>
                        </Grid>

                        <StackPanel x:Name="PanelIndicadorPaginas" Grid.Row="1"
                                    Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,10,0,0" Visibility="Collapsed"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,14,0,14">
                        <Button x:Name="BtnVolverPaso"
                                Style="{StaticResource EstiloBtnTexto}"
                                Padding="6,4" HorizontalAlignment="Left"
                                Click="BtnVolverPaso_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.6"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoVolverUrl}"/>
                                <TextBlock Text="ATRÁS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnSiguientePaso"
                                Style="{StaticResource EstiloBtnTexto}"
                                Padding="6,4" Visibility="Collapsed"
                                HorizontalAlignment="Right"
                                Click="BtnSiguientePaso_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SIGUIENTE" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.85"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoSiguienteUrl}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ──────────────────────────────────────
                 VISTA COMPLEMENTOS
                 Muestra complementos del pilar seleccionado agrupados por subcategoría
                 ────────────────────────────────────── -->
            <Grid x:Name="GridComplementos" Visibility="Collapsed">
                <Grid Margin="28,20,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera: icono padre + título contextual -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <Border CornerRadius="6" Padding="10,4" HorizontalAlignment="Left"
                                Background="#1422C55E" BorderBrush="#2022C55E" BorderThickness="1"
                                Margin="0,0,0,8">
                            <TextBlock Text="OPCIONAL — puedes saltarte este paso"
                                       FontSize="9" FontWeight="Bold" Foreground="#22C55E"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                <Image x:Name="ImgPadreComplemento"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTituloComplementos" FontSize="26" FontWeight="Black"
                                           Foreground="{StaticResource AcentoVerde}"/>
                                <TextBlock x:Name="TxtDescComplementos" FontSize="12"
                                           Foreground="{StaticResource TextoSecundario}"
                                           Opacity="0.85"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Subcategorías con cards por cada una -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaSubcategorias" ButtonBase.Click="ComplementoSlotClick">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,24">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2"
                                                       Fill="{StaticResource AcentoVerde}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource TextoSecundario}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding Nombre, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding SlotsVisibles}"
                                                      ItemTemplateSelector="{StaticResource ComplementoCardSelectorTemplate}"
                                                      Loaded="ComplementoInnerItems_Loaded">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,14,0,14">
                        <Button x:Name="BtnVolverComplementos"
                                Style="{StaticResource EstiloBtnTexto}"
                                HorizontalAlignment="Left" Padding="6,4"
                                Click="BtnVolverComplementos_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.6"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoVolverUrl}"/>
                                <TextBlock Text="ATRÁS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnSiguienteComplementos"
                                Style="{StaticResource EstiloBtnTexto}"
                                HorizontalAlignment="Right" Padding="6,4"
                                Click="BtnSiguienteComplementos_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SIGUIENTE" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.85"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoSiguienteUrl}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ──────────────────────────────────────
                 VISTA SELECTOR
                 ────────────────────────────────────── -->
            <Grid x:Name="GridSelector" Visibility="Collapsed">
                <Grid Margin="28,20,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource EstiloBtnTexto}"
                                FontSize="13" FontWeight="SemiBold"
                                Padding="0" Margin="0,0,16,0" VerticalAlignment="Center"
                                Click="BtnVolverDesdeSelector_Click">
                            <Image Width="40" Height="40" Stretch="Uniform" Opacity="0.5"
                                   Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoVolverUrl}"/>
                        </Button>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtTituloSelector"
                                       Foreground="{StaticResource TextoPrimario}"
                                       FontSize="20" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtSubtituloSelector"
                                       Foreground="{StaticResource TextoSecundario}"
                                       FontSize="11" Opacity="0.85"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,0,0,14" MaxWidth="360" HorizontalAlignment="Left"
                            Background="{StaticResource FondoPaneles}"
                            BorderBrush="{StaticResource BordeGeneral}"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <TextBox x:Name="TxtBuscador"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextoPrimario}"
                                     CaretBrush="{StaticResource AcentoCian}"
                                     BorderThickness="0" FontSize="13" Padding="12,8"
                                     TextChanged="TxtBuscador_TextChanged"/>
                            <TextBlock Text="Buscar..." IsHitTestVisible="False"
                                       Margin="14,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextoSecundario}" Opacity="0.65">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtBuscador}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnPaginaAnteriorSelector" Grid.Column="0"
                                Style="{StaticResource EstiloBtnTexto}" Padding="4"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed" Click="BtnPaginaAnteriorSelector_Click">
                            <Image Width="36" Height="36" Stretch="Uniform" Opacity="0.7"
                                   Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoPaginaAnteriorUrl}"/>
                        </Button>

                        <ItemsControl x:Name="ListaModulosSelector" Grid.Column="1"
                                      ItemTemplate="{StaticResource PlantillaTarjetaAsistida}"
                                      MouseLeftButtonDown="SelectorModulo_Click">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Button x:Name="BtnPaginaSiguienteSelector" Grid.Column="2"
                                Style="{StaticResource EstiloBtnTexto}" Padding="4"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed" Click="BtnPaginaSiguienteSelector_Click">
                            <Image Width="36" Height="36" Stretch="Uniform" Opacity="0.7"
                                   Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoPaginaSiguienteUrl}"/>
                        </Button>
                    </Grid>

                    <!-- Indicador de página estilo PS5 -->
                    <StackPanel x:Name="PanelIndicadorPaginasSelector" Grid.Row="3"
                                Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,8,0,4" Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <!-- ──────────────────────────────────────
                 VISTA PERSONALIZACIÓN HEKATE
                 Secciones agrupadas por complemento + imágenes personalizadas
                 ────────────────────────────────────── -->
            <Grid x:Name="GridPersonalizacionHekate" Visibility="Collapsed">
                <Grid Margin="28,20,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <Border CornerRadius="6" Padding="10,4" HorizontalAlignment="Left"
                                Background="#1414B8A8" BorderBrush="#2014B8A8" BorderThickness="1" Margin="0,0,0,8">
                            <TextBlock Text="OPCIONAL — puedes saltarte este paso"
                                       FontSize="9" FontWeight="Bold" Foreground="#14B8A8"/>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Image x:Name="ImgIconoHekate" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTituloPersonalizacion" FontSize="26" FontWeight="Black"
                                           Foreground="{StaticResource AcentoCian}"/>
                                <TextBlock x:Name="TxtDescPersonalizacion" FontSize="12"
                                           Foreground="{StaticResource TextoSecundario}" Opacity="0.85"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Secciones de módulos (tarjetas cuadradas por complemento) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaSeccionesHekate">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,24">
                                        <!-- Título de sección -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Rectangle Width="3" Height="14" RadiusX="2" RadiusY="2"
                                                       Fill="{Binding ColorNeon, Converter={StaticResource ColorNeonConverter}}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Titulo}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource TextoPrimario}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Cards cuadradas: módulos seleccionados + botón Agregar -->
                                        <ItemsControl ItemsSource="{Binding SlotsVisiblesCard}"
                                                      ItemTemplateSelector="{StaticResource HekateCardSelector}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Navegación -->
                    <Grid Grid.Row="2" Margin="0,14,0,14">
                        <Button Style="{StaticResource EstiloBtnTexto}" HorizontalAlignment="Left" Padding="6,4"
                                Click="BtnVolverHekate_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.6"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoVolverUrl}"/>
                                <TextBlock Text="ATRÁS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource EstiloBtnTexto}" HorizontalAlignment="Right" Padding="6,4"
                                Click="BtnSiguienteHekate_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SIGUIENTE" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.85"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoSiguienteUrl}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ──────────────────────────────────────
                 OVERLAY MULTI-SELECTOR
                 Panel flotante sobre GridPersonalizacionHekate
                 ────────────────────────────────────── -->
            <Grid x:Name="GridSelectorMultiHekate" Visibility="Collapsed" Panel.ZIndex="50">
                <!-- Fondo oscuro semi-transparente -->
                <Border Background="#CC05050A" MouseLeftButtonDown="BtnCancelarSelectorMulti_Click"/>

                <!-- Panel flotante centrado -->
                <Border Width="720" MaxHeight="560"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        CornerRadius="16" Background="#0F0F18"
                        BorderBrush="#2A2A35" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.7"/>
                    </Border.Effect>
                    <Grid Margin="24,20,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Título + cerrar -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTituloSelectorMulti"
                                           FontSize="20" FontWeight="Black"
                                           Foreground="{StaticResource AcentoCian}"/>
                                <TextBlock Text="Selecciona uno o varios. Confirma con Aceptar."
                                           FontSize="11" Foreground="{StaticResource TextoSecundario}" Opacity="0.8"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Click="BtnCancelarSelectorMulti_Click">
                                <TextBlock Text="&#x2715;" FontSize="16"
                                           Foreground="{StaticResource TextoSecundario}" Opacity="0.7"/>
                            </Button>
                        </Grid>

                        <!-- Buscador -->
                        <Border Grid.Row="1" Margin="0,0,0,14" Width="280" HorizontalAlignment="Left"
                                Background="{StaticResource FondoPaneles}"
                                BorderBrush="{StaticResource BordeGeneral}"
                                BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <TextBox x:Name="TxtBuscadorMulti"
                                         Background="Transparent"
                                         Foreground="{StaticResource TextoPrimario}"
                                         CaretBrush="{StaticResource AcentoCian}"
                                         BorderThickness="0" FontSize="13" Padding="12,8"
                                         TextChanged="TxtBuscadorMulti_TextChanged"/>
                                <TextBlock Text="Buscar..." IsHitTestVisible="False"
                                           Margin="14,0,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextoSecundario}" Opacity="0.5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=TxtBuscadorMulti}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Lista de módulos con checkmark -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ListaMultiSelector"
                                          MouseLeftButtonDown="ItemMultiSelector_Click">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6">
                                            <!-- Halo neon rotatorio -->
                                            <Border x:Name="HaloMulti"
                                                    Width="165" Height="155"
                                                    CornerRadius="18"
                                                    BorderThickness="5"
                                                    BorderBrush="{StaticResource PincelSpotGris}"
                                                    Background="Transparent"
                                                    Opacity="1"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Border.RenderTransform>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <!-- Tarjeta módulo -->
                                            <Border x:Name="CuerpoMulti"
                                                    Width="150" Height="140"
                                                    CornerRadius="14"
                                                    Background="#0F0F15"
                                                    BorderThickness="1.5"
                                                    BorderBrush="#2A2A35"
                                                    Cursor="Hand"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Border.RenderTransform>
                                                <Border.Effect>
                                                    <DropShadowEffect x:Name="SombraMulti" BlurRadius="10" ShadowDepth="0"
                                                                      Color="Black" Opacity="0.5"/>
                                                </Border.Effect>
                                                <Grid Margin="10,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="14"/>
                                                    </Grid.RowDefinitions>
                                                    <Image Grid.Row="0"
                                                           Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                                                           Stretch="Uniform" MaxHeight="54"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Nombre}"
                                                               Foreground="White" FontSize="11" FontWeight="Bold"
                                                               TextAlignment="Center" TextWrapping="Wrap"
                                                               MaxHeight="30" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Row="2"
                                                               Text="{Binding Version}"
                                                               Foreground="#50FFFFFF" FontSize="9"
                                                               TextAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <!-- Checkmark overlay -->
                                            <Border x:Name="CheckOverlay"
                                                    Width="22" Height="22" CornerRadius="11"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,4,4,0"
                                                    Background="{StaticResource AcentoVerde}"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="&#x2713;" FontSize="11" FontWeight="Bold"
                                                           Foreground="Black"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CuerpoMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                                             To="1.04" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="CuerpoMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                                             To="1.04" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="HaloMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                                             To="1.04" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="HaloMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                                             To="1.04" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="SombraMulti"
                                                                             Storyboard.TargetProperty="BlurRadius"
                                                                             To="22" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CuerpoMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                                             To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="CuerpoMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                                             To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="HaloMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleX"
                                                                             To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="HaloMulti"
                                                                             Storyboard.TargetProperty="(RenderTransform).ScaleY"
                                                                             To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="SombraMulti"
                                                                             Storyboard.TargetProperty="BlurRadius"
                                                                             To="10" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <!-- Seleccionado -->
                                            <DataTrigger Binding="{Binding Seleccionado}" Value="True">
                                                <Setter TargetName="CuerpoMulti"  Property="BorderBrush" Value="{StaticResource AcentoVerde}"/>
                                                <Setter TargetName="HaloMulti"    Property="BorderBrush" Value="{StaticResource PincelSpotVerde}"/>
                                                <Setter TargetName="CheckOverlay" Property="Visibility"  Value="Visible"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="HaloVerdeMulti">
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="HaloMulti"
                                                                Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                                                From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="HaloVerdeMulti"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Botones Aceptar / Cancelar -->
                        <Grid Grid.Row="3" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="CANCELAR"
                                    Style="{StaticResource EstiloBotonAccionBase}"
                                    Height="42" Width="200" Margin="0"
                                    Click="BtnCancelarSelectorMulti_Click"/>
                            <Button Grid.Column="2"
                                    Content="ACEPTAR"
                                    Style="{StaticResource EstiloBotonInstalar}"
                                    Height="42" Width="200" Margin="0"
                                    Click="BtnAceptarSelectorMulti_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>


            <!-- ──────────────────────────────────────
                 VISTA EDITOR DE IMAGEN
                 Conversor drag-and-drop para imágenes de Hekate
                 ────────────────────────────────────── -->
            <Grid x:Name="GridEditorImagen" Visibility="Collapsed">
                <Grid Margin="28,20,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <Border CornerRadius="6" Padding="10,4" HorizontalAlignment="Left"
                                Background="#1422C55E" BorderBrush="#2022C55E" BorderThickness="1"
                                Margin="0,0,0,8">
                            <TextBlock Text="PERSONALIZACIÓN" FontSize="9" FontWeight="Bold" Foreground="#22C55E"/>
                        </Border>
                        <TextBlock x:Name="TxtTituloEditorImagen" FontSize="26" FontWeight="Black"
                                   Foreground="{StaticResource AcentoVerde}"/>
                        <TextBlock x:Name="TxtDescEditorImagen" FontSize="12"
                                   Foreground="{StaticResource TextoSecundario}" Opacity="0.85"/>
                    </StackPanel>

                    <!-- Zona drag-drop + preview -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Zona de arrastre -->
                        <Border Grid.Column="0" x:Name="ZonaDropImagen"
                                CornerRadius="16" BorderThickness="2"
                                BorderBrush="{StaticResource BordeGeneral}"
                                Background="#08FFFFFF"
                                AllowDrop="True"
                                Drop="ZonaDropImagen_Drop"
                                DragOver="ZonaDropImagen_DragOver"
                                DragLeave="ZonaDropImagen_DragLeave"
                                MinHeight="200">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#x2B60;" FontSize="42"
                                           Foreground="{StaticResource TextoSecundario}"
                                           HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="Arrastra tu imagen aquí" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           HorizontalAlignment="Center" Margin="0,10,0,4"/>
                                <TextBlock x:Name="TxtEspecsImagen" FontSize="10"
                                           Foreground="{StaticResource TextoSecundario}"
                                           HorizontalAlignment="Center" Opacity="0.65"
                                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                <Button x:Name="BtnExplorarImagen"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Margin="0,10,0,0"
                                        Click="BtnExplorarImagen_Click">
                                    <TextBlock Text="o explora archivos" FontSize="11"
                                               Foreground="{StaticResource AcentoVerde}"
                                               TextDecorations="Underline"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Vista previa -->
                        <Border Grid.Column="2" CornerRadius="16" BorderThickness="1.5"
                                BorderBrush="{StaticResource BordeGeneral}"
                                Background="{StaticResource FondoPaneles}"
                                MinHeight="200">
                            <Grid>
                                <TextBlock x:Name="TxtPreviewPlaceholder"
                                           Text="Vista previa" FontSize="12"
                                           Foreground="{StaticResource TextoSecundario}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.35"/>
                                <Image x:Name="ImgPreviewEditor" Stretch="Uniform" Margin="12"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Botones -->
                    <Grid Grid.Row="2" Margin="0,14,0,14">
                        <Button x:Name="BtnVolverEditorImagen"
                                Style="{StaticResource EstiloBtnTexto}"
                                HorizontalAlignment="Left" Padding="6,4"
                                Click="BtnVolverEditorImagen_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.6"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoVolverUrl}"/>
                                <TextBlock Text="ATRÁS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnAplicarImagen"
                                Content="APLICAR IMAGEN"
                                Style="{StaticResource EstiloBotonInstalar}"
                                Width="200" HorizontalAlignment="Right"
                                IsEnabled="False"
                                Click="BtnAplicarImagen_Click"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ──────────────────────────────────────
                 VISTA RESUMEN — agrupado por padre
                 ────────────────────────────────────── -->
            <Grid x:Name="GridResumen" Visibility="Collapsed">
                <Grid Margin="28,20,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Resumen" FontSize="30" FontWeight="Black"
                                   Foreground="{StaticResource AcentoVerde}"/>
                        <TextBlock Text="Revisa tu selección antes de instalar."
                                   FontSize="13" Foreground="{StaticResource TextoSecundario}"
                                   Opacity="0.85" Margin="0,6,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaResumen">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="{Binding MargenResumen}" CornerRadius="12" Height="70"
                                            Background="{StaticResource FondoPaneles}"
                                            BorderThickness="1.5"
                                            BorderBrush="{Binding ColorNeon, Converter={StaticResource ColorNeonConverter}}">
                                        <Grid Margin="16,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="38" Height="38"
                                                    CornerRadius="10" VerticalAlignment="Center">
                                                <Image Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding PasoTitulo}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource TextoSecundario}" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Nombre}"
                                                           FontSize="16" FontWeight="Bold"
                                                           Foreground="{StaticResource TextoPrimario}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Version}"
                                                       FontSize="10" Foreground="{StaticResource TextoSecundario}"
                                                       Opacity="0.7" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,14,0,14">
                        <Button Style="{StaticResource EstiloBtnTexto}"
                                HorizontalAlignment="Left" Padding="6,4"
                                Click="BtnVolverResumen_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="22" Height="22" Stretch="Uniform" Opacity="0.6"
                                       Source="{Binding Source={x:Static core:UIConfigService.Current}, Path=IconoVolverUrl}"/>
                                <TextBlock Text="ATRÁS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnInstalarAsistido" Content="INSTALAR AHORA"
                                Style="{StaticResource EstiloBotonInstalar}"
                                Width="220" HorizontalAlignment="Right"
                                Click="BtnInstalarAsistido_Click"/>
                    </Grid>
                </Grid>
            </Grid>

        </Grid>

        <!-- ═══════════════════════════════════════════
             SIDEBAR CHECKOUT — vertical, columna derecha
             ═══════════════════════════════════════════ -->
        <Border x:Name="BarraCheckout" Grid.Row="1" Grid.Column="1"
                Visibility="Collapsed"
                Background="#08080F"
                BorderBrush="#22FFFFFF"
                BorderThickness="1,0,0,0">
            <Grid Margin="12,16,12,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Contador tipo badge -->
                <Border Grid.Row="0" CornerRadius="8"
                        Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1"
                        Padding="10,6" Margin="0,0,0,12">
                    <TextBlock x:Name="TxtContadorCheckout"
                               Text="0 pilares"
                               Foreground="{StaticResource TextoPrimario}"
                               FontSize="10" FontWeight="Bold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Chips verticales scrolleables -->
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CheckoutLista">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="8,8"
                                        CornerRadius="10"
                                        Background="#14FFFFFF"
                                        BorderBrush="{Binding ColorNeon, Converter={StaticResource ColorNeonConverter}}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Icono -->
                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Image Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <!-- Nombre + versión -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}"
                                                       Foreground="{StaticResource TextoPrimario}"
                                                       FontSize="11" FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Version}"
                                                       Foreground="{StaticResource TextoSecundario}"
                                                       FontSize="9" Opacity="0.75"/>
                                        </StackPanel>
                                        <!-- Botón quitar -->
                                        <Button Grid.Column="2" Tag="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" VerticalAlignment="Center" Margin="4,0,0,0"
                                                Click="BtnEliminarCheckout_Click">
                                            <TextBlock Text="&#x2715;" FontSize="9"
                                                       Foreground="{StaticResource TextoSecundario}"
                                                       Opacity="0.7"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>
