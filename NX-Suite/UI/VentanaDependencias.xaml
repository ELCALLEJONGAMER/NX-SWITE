<Window x:Class="NX_Suite.UI.VentanaDependencias"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dependencias - NX-SWITE"
        Width="660" Height="540"
        MinWidth="580" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>

        <!-- Checkbox personalizado -->
        <Style x:Key="CheckBoxDeps" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd"
                                Width="22" Height="22"
                                CornerRadius="6"
                                Background="#0F0F15"
                                BorderBrush="#2A2A35"
                                BorderThickness="1.5">
                            <Path x:Name="CheckMark"
                                  Data="M 4,11 L 9,16 L 18,5"
                                  Stroke="#00D2FF"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00D2FF"/>
                                <Setter TargetName="Bd" Property="Background" Value="#071820"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00A8CC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Boton primario cyan -->
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#07070D"/>
            <Setter Property="Background" Value="#00D2FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33DDFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Boton secundario ghost -->
        <Style x:Key="BtnSecundario" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#505060"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Contenedor raiz con sombra -->
    <Border Background="#07070D"
            CornerRadius="16"
            BorderBrush="#1A1A28"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.85"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- BARRA SUPERIOR -->
            <Border Grid.Row="0"
                    Background="#05050A"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TopBar_Drag">
                <Grid Margin="22,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="#FFD54A" Margin="0,0,10,0"/>
                        <TextBlock Text="DEPENDENCIAS REQUERIDAS"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#FFD54A"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnCerrar_Click"
                            Width="28" Height="28">
                        <TextBlock Text="X" FontSize="12" Foreground="#505060"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENIDO -->
            <Grid Grid.Row="1" Margin="28,22,28,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Titulo y subtitulo -->
                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="TxtTitulo"
                               FontSize="24"
                               FontWeight="Black"
                               Foreground="White"/>
                    <TextBlock x:Name="TxtSubtitulo"
                               FontSize="13"
                               Foreground="#707080"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Badges de resumen -->
                <StackPanel x:Name="PanelResumen"
                            Grid.Row="2"
                            Orientation="Horizontal"/>

                <!-- Lista scrollable de tarjetas -->
                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,4,0">
                    <ItemsControl x:Name="ListaDependencias">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D0D15"
                                        BorderBrush="#1E1E28"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,0,0,8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                                          Color="Black" Opacity="0.4"/>
                                    </Border.Effect>

                                    <Grid Margin="0,14,18,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Barra lateral de color segun estado -->
                                        <Border Grid.Column="0"
                                                CornerRadius="3"
                                                Background="{Binding ColorHexEstado,
                                                    Converter={StaticResource ColorNeonConverter}}"/>

                                        <!-- Informacion del modulo -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Modulo.Nombre}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                            <Border CornerRadius="5"
                                                    Margin="0,5,0,0"
                                                    HorizontalAlignment="Left"
                                                    Padding="8,3">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#1A1A28"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding TextoEstado}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding ColorHexEstado,
                                                               Converter={StaticResource ColorNeonConverter}}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Modulo.Descripcion}"
                                                       FontSize="12"
                                                       Foreground="#505060"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="36"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>

                                        <!-- Checkbox de seleccion -->
                                        <CheckBox Grid.Column="4"
                                                  IsChecked="{Binding Seleccionada, Mode=TwoWay}"
                                                  IsEnabled="{Binding EsAccionable}"
                                                  Style="{StaticResource CheckBoxDeps}"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- BARRA DE ACCIONES -->
            <Border Grid.Row="2"
                    Background="#05050A"
                    CornerRadius="0,0,16,16"
                    BorderBrush="#1A1A28"
                    BorderThickness="0,1,0,0"
                    Padding="28,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="BtnInstalar"
                            Content="Instalar seleccionadas"
                            Style="{StaticResource BtnPrimario}"
                            Click="BtnInstalar_Click"/>

                    <Button Grid.Column="2"
                            Content="Continuar sin instalar"
                            Style="{StaticResource BtnSecundario}"
                            Click="BtnContinuarSin_Click"/>

                    <Button Grid.Column="4"
                            Content="Cancelar"
                            Style="{StaticResource BtnSecundario}"
                            Click="BtnCancelar_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
