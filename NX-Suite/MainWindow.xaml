<Window x:Class="NX_Suite.MainWindow"
        xmlns:controles="clr-namespace:NX_Suite.UI.Controles"
        xmlns:local="clr-namespace:NX_Suite"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NX-Suite" Height="700" Width="1200" 
        WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent" WindowStartupLocation="CenterScreen">

    <Border CornerRadius="15" Background="#0D0D12" BorderBrush="#2A2A35" BorderThickness="1">
        <Grid x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Panel.ZIndex="10">
                <controles:PanelIzquierdo x:Name="MenuMundos" Width="240"/>

                <controles:RetractilIzq x:Name="FiltrosRetractil"/>
            </StackPanel>

            <Grid Grid.Column="1" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown"/>

                    <Grid Grid.Row="1" Margin="20">
                        <ScrollViewer x:Name="VistaCatalogo" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                            <ItemsControl x:Name="CatalogoModulos" ItemTemplate="{StaticResource PlantillaModuloGamer}"
              MouseLeftButtonDown="Catalogo_ClickTarjeta"
              ButtonBase.Click="Catalogo_ClickBoton">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid x:Name="VistaDetalle" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button Style="{StaticResource EstiloBotonVolver}"
                                    Click="BtnVolver_Click"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="pack://application:,,,/Assets/back_icon.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>

                                    <TextBlock Text="VOLVER AL LISTADO"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border CornerRadius="15" BorderThickness="2" BorderBrush="#00D2FF" Height="250" VerticalAlignment="Top">
                                    <Image x:Name="ImgDetalle" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="30,0">
                                    <TextBlock x:Name="TxtTituloDetalle" FontSize="36" FontWeight="Bold" Foreground="#00D2FF" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="TxtVersionDetalle" FontSize="14" Foreground="#BD00FF" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                    <TextBlock Text="DESCRIPCIÓN" Foreground="#707080" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="TxtDescDetalle" FontSize="16" Foreground="White" TextWrapping="Wrap" Opacity="0.8" LineHeight="24"/>
                                </StackPanel>
                            </Grid>

                            <UniformGrid Grid.Row="2" Columns="4" Height="65" Margin="0,20,0,0">
                                <Button Content="INSTALAR" Style="{StaticResource EstiloBotonInstalar}" Click="BtnInstalar_Click"/>
                                <Button Content="ACTUALIZAR" Style="{StaticResource EstiloBotonActualizar}" Click="BtnInstalar_Click"/>
                                <Button Content="BORRAR" Style="{StaticResource EstiloBotonEliminar}" Click="BtnBorrar_Click"/>
                                <Button x:Name="BtnWebDetalle" Content="SITIO WEB" Style="{StaticResource EstiloBotonMenu}" Margin="5"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Grid>

                <Border x:Name="FondoOscuro" Background="Black" Opacity="0" Visibility="Collapsed" Panel.ZIndex="100">
                    <Button Background="Transparent" BorderThickness="0" Click="BtnCerrarPaneles_Click"/>
                </Border>

                <Grid x:Name="OverlayCarga" Visibility="Collapsed" Panel.ZIndex="1000">
                    <Border Background="#E605050A"/>

                    <Border Background="#12121A" BorderBrush="#2A2A35" BorderThickness="2" CornerRadius="20" Width="550" Height="450" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Margin="40">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                <TextBlock Text="O P E R A C I Ó N   E N   C U R S O" Foreground="#BD00FF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtCargaSubtitulo" Text="Instalando Paquete" Foreground="#00D2FF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>

                            <Grid Grid.Row="1" Width="100" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20">
                                <Path Data="M 50,0 A 50,50 0 1 1 0,50" Stroke="#00D2FF" StrokeThickness="6" StrokeEndLineCap="Round" Stretch="None">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#00D2FF" BlurRadius="15" ShadowDepth="0"/>
                                    </Path.Effect>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="GiroSpinner" CenterX="50" CenterY="50"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="GiroSpinner" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                                <TextBlock x:Name="TxtCargaPorcentaje" Text="0%" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Row="2" Margin="0,0,0,30">
                                <Border Background="#1A1A24" CornerRadius="10" Height="12" BorderBrush="#2A2A35" BorderThickness="1" ClipToBounds="True" Margin="0,0,0,10">
                                    <Border x:Name="BarraProgresoNeon" Background="#00D2FF" Width="0" HorizontalAlignment="Left" CornerRadius="5">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#00D2FF" BlurRadius="10" ShadowDepth="0"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock x:Name="TxtCargaDetalle" Text="Preparando motores..." Foreground="#707080" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <UniformGrid Grid.Row="3" Columns="2" Rows="2" Margin="10,0">
                                <TextBlock x:Name="TxtPaso1" Text="1. Descargando paquete" Foreground="#707080" FontSize="14" FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock x:Name="TxtPaso2" Text="2. Extrayendo archivos" Foreground="#707080" FontSize="14" FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock x:Name="TxtPaso3" Text="3. Aplicando en SD" Foreground="#707080" FontSize="14" FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock x:Name="TxtPaso4" Text="4. Limpiando temporales" Foreground="#707080" FontSize="14" FontWeight="SemiBold" Margin="0,5"/>
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <Grid Grid.Column="2" Panel.ZIndex="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <controles:RetractilDer x:Name="ArsenalRetractil" Grid.Column="0"/>
                <controles:PanelDerecho x:Name="InfoSD" Grid.Column="1"/>
            </Grid>
        </Grid>
    </Border>
</Window>