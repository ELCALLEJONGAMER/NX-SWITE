<Window x:Class="NX_Suite.MainWindow"
        xmlns:controles="clr-namespace:NX_Suite.UI.Controles"
        xmlns:local="clr-namespace:NX_Suite"
        xmlns:core="clr-namespace:NX_Suite.Core"
        xmlns:cfg="clr-namespace:NX_Suite.Core.Configuracion"
        xmlns:models="clr-namespace:NX_Suite.Models"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NX-Suite"
        MinHeight="720"
        MinWidth="1280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="15"
            Background="#0D0D12"
            BorderBrush="#2A2A35"
            BorderThickness="1">
        <Grid x:Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════
                 TOP BAR  –  arrastre + título + acciones
                 ══════════════════════════════════════════ -->
            <Border x:Name="BarraTopBar"
                    Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                    Background="#0F0F16"
                    BorderBrush="#2A2A35"
                    BorderThickness="0,0,0,1"
                    CornerRadius="15,15,0,0"
                    Height="52"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Título / logo + iconos izquierda -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">

                        <!-- Logo (no clickable) -->
                        <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                            <TextBlock Text="NX" Foreground="#00D2FF"
                                       FontSize="13" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="-SWITE" Foreground="#707080"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="14" Fill="#2A2A35" Margin="10,0"/>
                            <TextBlock x:Name="TxtTopBarSeccion" Text="Catálogo"
                                       Foreground="#505060" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Rectangle Width="1" Height="20" Fill="#2A2A35" Margin="12,0"/>

                        <!-- Botón Cola de Procesos -->
                        <Button x:Name="BtnAbrirQueue"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Margin="0,0,2,0" Width="32" Height="32"
                                ToolTip="Cola de procesos"
                                Click="BtnAbrirQueue_Click"
                                Style="{StaticResource EstiloBotonTopBar}">
                            <Grid Width="32" Height="32">
                                <controles:GifIcon Width="32" Height="32" Stretch="Uniform" Opacity="0.65"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       AnimateOnHover="True"
                                       Url="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoQueueUrl}"/>
                                <Border x:Name="BadgeQueue"
                                        Background="#BD00FF" CornerRadius="6"
                                        MinWidth="13" Height="13" Padding="2,0"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-3,-3,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Source={x:Static core:Servicios.Cola}, Path=TieneActivos}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Source={x:Static core:Servicios.Cola}, Path=ContadorActivos}"
                                               FontSize="8" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Notificaciones -->
                        <Button x:Name="BtnNotificaciones"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Margin="30,0,2,0" Width="32" Height="32"
                                ToolTip="Notificaciones"
                                Style="{StaticResource EstiloBotonTopBar}">
                            <controles:GifIcon Width="32" Height="32" Stretch="Uniform" Opacity="0.55"
                                   AnimateOnHover="True"
                                   Url="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoBellUrl}"/>
                        </Button>

                        <!-- Mensajes / Noticias -->
                        <Button x:Name="BtnMensajes"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Margin="30,0,2,0" Width="32" Height="32"
                                ToolTip="Mensajes"
                                Style="{StaticResource EstiloBotonTopBar}">
                            <controles:GifIcon Width="32" Height="32" Stretch="Uniform" Opacity="0.55"
                                   AnimateOnHover="True"
                                   Url="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoMailUrl}"/>
                        </Button>

                        <!-- Actualizaciones -->
                        <Button x:Name="BtnActualizaciones"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Margin="30,0,2,0" Width="32" Height="32"
                                ToolTip="Actualizaciones"
                                Click="BtnActualizaciones_Click"
                                Style="{StaticResource EstiloBotonTopBar}">
                            <Grid Width="32" Height="32">
                                <controles:GifIcon Width="32" Height="32" Stretch="Uniform" Opacity="0.55"
                                       AnimateOnHover="True"
                                       Url="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoUpdateUrl}"/>
                                <!-- Badge verde pulsante: visible cuando hay actualización -->
                                <Border x:Name="BadgeActualizacion"
                                        Background="#22C55E" CornerRadius="5"
                                        Width="9" Height="9"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-2,-2,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Source={x:Static core:Servicios.Actualizacion}, Path=HayActualizacion}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Border.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.2"
                                                                     Duration="0:0:0.9"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </Grid>
                        </Button>

                    </StackPanel>

                    <!-- Minimizar y Cerrar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="BtnMinimizar"
                                Width="28" Height="28"
                                Cursor="Hand"
                                Click="BtnMinimizar_Click"
                                ToolTip="Minimizar"
                                Style="{StaticResource EstiloBotonTopBar}">
                            <Path Data="M 4,14 L 24,14" Stroke="#707080" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Button>
                        <Button x:Name="BtnCerrar"
                                Width="28" Height="28"
                                Cursor="Hand"
                                Click="BtnCerrar_Click"
                                ToolTip="Cerrar"
                                Style="{StaticResource EstiloBotonTopBarCerrar}">
                            <Path Data="M 5,5 L 23,23 M 23,5 L 5,23" Stroke="#707080" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Paneles laterales y contenido central en fila 1 -->
            <StackPanel x:Name="PanelLateralIzquierdo"
                        Grid.Row="1" Grid.Column="0"
                        Orientation="Horizontal"
                        Panel.ZIndex="10">
                <controles:PanelIzquierdo x:Name="MenuMundos" Width="220"/>
            </StackPanel>

            <Grid x:Name="GridContenidoCentral" Grid.Row="1" Grid.Column="1" ClipToBounds="True">
                <Grid x:Name="GridContenidoCentralContenido">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,12,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Titulo y subtitulo (ocultos en modo asistido) -->
                        <Grid x:Name="PanelTituloSeccion"
                              Grid.Row="0" Margin="0,0,0,16" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTituloSeccion"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="#00D2FF"
                                           Margin="0,0,0,4" Text=""/>
                                <TextBlock x:Name="TxtSubtituloSeccion"
                                           Text="" Foreground="#707080"
                                           FontSize="11" FontWeight="SemiBold"
                                           Opacity="0.85"/>
                            </StackPanel>

                            <!-- Boton herramientas Hekate (solo visible en mundo personalizacion) -->
                            <Button x:Name="BtnHerramientasPersonalizacion"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="200" Height="38"
                                    Visibility="Collapsed"
                                    Cursor="Hand"
                                    Click="BtnHerramientasPersonalizacion_Click"
                                    Style="{StaticResource EstiloBotonAccionBase}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2699;" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Crear tema para hekate"
                                               FontSize="10" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Chips de filtro horizontal -->
                        <!-- Barra de búsqueda y chips de filtro -->
                        <Grid x:Name="PanelChipsFiltro"
                              Grid.Row="1"
                              Margin="0,0,0,10"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>

                            <!-- Chips de categoría -->
                            <ScrollViewer Grid.Column="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Center">
                                <ListBox x:Name="ChipsFiltro"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource EstiloItemChipFiltro}"
                                         ItemTemplate="{StaticResource PlantillaFiltroCentroMando}"
                                         SelectionChanged="ListaCategorias_SelectionChanged"
                                         PreviewMouseLeftButtonDown="ChipsFiltro_PreviewMouseLeftButtonDown">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                            </ScrollViewer>

                            <!-- Barra de búsqueda -->
                            <Border Grid.Column="1"
                                    CornerRadius="20"
                                    BorderThickness="2"
                                    BorderBrush="#2A2A35"
                                    Background="#0F0F15"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Height="34">
                                <Grid Margin="12,0">
                                    <TextBlock x:Name="PlaceholderBusqueda"
                                               Text="🔍  Buscar módulo..."
                                               Foreground="#505060"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                    <TextBox x:Name="TxtBusqueda"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#C0C0D0"
                                             FontSize="11"
                                             FocusVisualStyle="{x:Null}"
                                             VerticalAlignment="Center"
                                             CaretBrush="#00D2FF"
                                             TextChanged="TxtBusqueda_TextChanged"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Catálogo -->
                        <ScrollViewer x:Name="VistaCatalogo"
                                      Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <ItemsControl x:Name="CatalogoModulos"
                                          ItemTemplate="{StaticResource PlantillaModuloGamer}"
                                          MouseLeftButtonDown="Catalogo_ClickTarjeta"
                                          ButtonBase.Click="Catalogo_ClickBoton">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Detalle de módulo -->
                        <Grid x:Name="VistaDetalle" Grid.Row="2" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="190"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- ── Banner con blur glass ── -->
                            <Grid Grid.Row="0" ClipToBounds="True">
                                <!-- Imagen de fondo desenfocada (centrada) -->
                                <Rectangle RenderOptions.BitmapScalingMode="HighQuality">
                                    <Rectangle.Fill>
                                        <ImageBrush x:Name="BrushBannerDetalle"
                                                    Stretch="UniformToFill"
                                                    AlignmentX="Center"
                                                    AlignmentY="Center"/>
                                    </Rectangle.Fill>
                                    <Rectangle.Effect>
                                        <BlurEffect Radius="15"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <!-- Capa oscura sobre el banner -->
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#99050510" Offset="0"/>
                                            <GradientStop Color="#EE0D0D12" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Borde neon inferior del banner -->
                                <Border VerticalAlignment="Bottom" Height="1"
                                        Background="#2800D2FF" Opacity="0.6"/>
                                <!-- Botón volver (top-left) -->
                                <Button Style="{StaticResource EstiloBotonVolver}"
                                        Click="BtnVolver_Click"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10,10,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="2,0">
                                        <Path Data="M 7,1 L 1,6 L 7,11"
                                              Stroke="White" StrokeThickness="1.5"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="VOLVER"
                                                   FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <!-- Nombre del módulo centrado en el banner -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="0,20,0,0">
                                    <TextBlock x:Name="TxtTituloDetalle"
                                               FontSize="50" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#00D2FF" BlurRadius="20"
                                                              ShadowDepth="0" Opacity="0.7"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock x:Name="TxtVersionDetalle"
                                               FontSize="20" FontWeight="SemiBold"
                                               Foreground="#00D2FF"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- ── Row 1: columna izquierda (icono + etiquetas) + columna derecha (contenido) ── -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icono solapando el banner + etiquetas debajo -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Top"
                                            Margin="0,-56,0,0" Panel.ZIndex="20">
                                    <Border Width="150" Height="150"
                                            CornerRadius="0"
                                            BorderBrush="#00D2FF" BorderThickness="2"
                                            Background="#1A0D0D12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#00D2FF" BlurRadius="50"
                                                              ShadowDepth="0" Opacity="0.50"/>
                                        </Border.Effect>
                                        <Image x:Name="ImgDetalle" Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <!-- Etiquetas debajo del icono -->
                                    <ItemsControl x:Name="ListaEtiquetasDetalle" Margin="4,10,4,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="5" Padding="6,3" Margin="0,0,4,4"
                                                        BorderBrush="#2A2A35" BorderThickness="1"
                                                        Background="#1A1A25">
                                                    <TextBlock Text="{Binding}" FontSize="9"
                                                               Foreground="#707080" FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Contenido principal + cache -->
                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                              Padding="0,0,4,0">
                                    <Grid Margin="8,18,16,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="210"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Info principal -->
                                        <StackPanel Grid.Column="0" Margin="0,0,14,0">

                                            <!-- Estado de instalación -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border x:Name="BadgeEstadoDetalle"
                                                        CornerRadius="6" Padding="20,3">
                                                    <TextBlock x:Name="TxtEstadoDetalle"
                                                               FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock x:Name="TxtVersionInstaladaDetalle"
                                                           FontSize="11" Foreground="#707080"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0"/>
                                            </StackPanel>

                                            <!-- Descripción -->
                                            <TextBlock Text="DESCRIPCIÓN"
                                                       Foreground="#707080"
                                                       FontSize="10" FontWeight="Bold"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock x:Name="TxtDescDetalle"
                                                       FontSize="14" Foreground="White"
                                                       TextWrapping="Wrap"
                                                       Opacity="0.85" LineHeight="22"
                                                       Margin="0,0,0,18"/>

                                            <!-- Capturas de pantalla -->
                                            <StackPanel x:Name="PanelScreenshots" Visibility="Collapsed"
                                                        Margin="0,0,0,10">
                                                <TextBlock Text="CAPTURAS" Foreground="#707080"
                                                           FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Disabled">
                                                    <ItemsControl x:Name="ListaScreenshots">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="224" Height="132" Margin="0,0,10,0"
                                                                        CornerRadius="10" ClipToBounds="True"
                                                                        BorderBrush="#2A2A35" BorderThickness="1">
                                                                    <Image Source="{Binding}" Stretch="UniformToFill"
                                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>

                                        </StackPanel>

                                        <!-- Cache local (columna derecha) -->
                                        <Border x:Name="PanelCacheDetalle" Grid.Column="1"
                                                Visibility="Collapsed"
                                                CornerRadius="15" Padding="14,12"
                                                Background="#0AFFFFFF"
                                                BorderBrush="#2A2A35" BorderThickness="3"
                                                VerticalAlignment="Top">
                                            <StackPanel>
                                                <TextBlock x:Name="TxtCabeceraCachePanel"
                                                           Text="CACHE EN PC" Foreground="#707080"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,12"
                                                           Visibility="Collapsed"/>

                                                <!-- ZIP -->
                                                <StackPanel x:Name="FilaCacheZip" Orientation="Horizontal"
                                                            Margin="0,5,0,20" Visibility="Collapsed"
                                                            VerticalAlignment="Center">
                                                    <Image Width="24" Height="24" Stretch="Uniform"
                                                           VerticalAlignment="Center" Opacity="0.7" Margin="0,0,8,0"
                                                           Source="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoZipUrl}"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="ZIP" Foreground="#707080" FontSize="14"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock x:Name="TxtTamanoZip" Foreground="#00D2FF"
                                                                   FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <Button x:Name="BtnBorrarCacheZip"
                                                            Background="Transparent" BorderThickness="0"
                                                            Cursor="Hand" VerticalAlignment="Center" Margin="60,0,0,0"
                                                            Click="BtnBorrarCacheZip_Click">
                                                        <Image Width="32" Height="32" Stretch="Uniform" Opacity="0.70"
                                                               Source="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoEliminarUrl}"/>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Separador ZIP/Carpeta (oculto: cache ahora en chips) -->
                                                <Rectangle x:Name="SepCacheTopRows"
                                                           Height="3" Fill="#2A2A35" Margin="0,0,0,20"
                                                           Visibility="Collapsed"/>

                                                <!-- Carpeta extraída -->
                                                <StackPanel x:Name="FilaCacheCarpeta" Orientation="Horizontal"
                                                            Visibility="Collapsed" VerticalAlignment="Center">
                                                    <Image Width="24" Height="24" Stretch="Uniform"
                                                           VerticalAlignment="Center" Opacity="0.7" Margin="0,0,8,0"
                                                           Source="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoCacheUrl}"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Extraído" Foreground="#707080" FontSize="14"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock x:Name="TxtTamanoCarpeta" Foreground="#00D2FF"
                                                                   FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <Button x:Name="BtnBorrarCacheCarpeta"
                                                            Background="Transparent" BorderThickness="0"
                                                            Cursor="Hand" VerticalAlignment="Center" Margin="45,0,0,0"
                                                            Click="BtnBorrarCacheCarpeta_Click">
                                                        <Image Width="32" Height="32" Stretch="Uniform" Opacity="0.70"
                                                               Source="{Binding Source={x:Static cfg:ConfiguracionRemota.Ui}, Path=IconoEliminarUrl}"/>
                                                    </Button>
                                                </StackPanel>

                                                <!-- ── Chips de versiones disponibles ── -->
                                                
                                                <TextBlock x:Name="TxtTituloVersiones"
                                                           Text="VERSIONES Y CACHÉ PC" Foreground="#505060"
                                                           FontSize="14" FontWeight="Bold"
                                                           Margin="0,0,0,8" Visibility="Collapsed"/>
                                                <StackPanel x:Name="PanelChipsVersiones"/>
                                            </StackPanel>
                                        </Border>

                                    </Grid>
                                </ScrollViewer>
                            </Grid>

                            <!-- ── Botones de acción inteligentes ── -->
                            <WrapPanel Grid.Row="2" HorizontalAlignment="Center"
                                       Margin="0,10,0,0" Orientation="Horizontal">
                                <Button x:Name="BtnInstalarDetalle"
                                        Content="INSTALAR"
                                        Style="{StaticResource EstiloBotonInstalar}"
                                        Width="160" Height="50"
                                        Click="BtnInstalar_Click"/>
                                <Button x:Name="BtnActualizarDetalle"
                                        Content="ACTUALIZAR"
                                        Style="{StaticResource EstiloBotonActualizar}"
                                        Width="160" Height="50"
                                        Click="BtnInstalar_Click"/>
                                <controles:SafeButton x:Name="BtnBorrarDetalle"
                                        Content="ELIMINAR"
                                        IsSafeMode="True"
                                        HoldTimeSeconds="2"
                                        Style="{StaticResource EstiloBotonEliminarHold}"
                                        Click="BtnBorrar_Click"/>
                                <Button x:Name="BtnAbrirUbicacionDetalle"
                                        Content="ABRIR UBICACIÓN"
                                        Style="{StaticResource EstiloBotonActualizar}"
                                        Width="160" Height="50"
                                        Click="BtnAbrirUbicacion_Click"/>
                                <Button x:Name="BtnSitioWebDetalle"
                                        Content="SITIO WEB"
                                        Style="{StaticResource EstiloBotonMenu}"
                                        Width="160" Height="50"
                                        Click="BtnSitioWeb_Click"/>
                            </WrapPanel>
                        </Grid>

                        <!-- Vista Asistida -->
                        <controles:VistaAsistida x:Name="VistaAsistida"
                                                  Grid.Row="2"
                                                  Visibility="Collapsed"/>

                        <!-- Vista Personalizacion -->
                        <controles:VistaPersonalizacion x:Name="VistaPersonalizacion"
                                                         Grid.Row="2"
                                                         Visibility="Collapsed"/>

                    </Grid>
                </Grid>

                <Border x:Name="FondoOscuro"
                        Background="Black"
                        Opacity="0"
                        Visibility="Collapsed"
                        Panel.ZIndex="100">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Click="BtnCerrarPaneles_Click"/>
                </Border>

                <Grid x:Name="OverlayCarga"
                      Visibility="Collapsed"
                      Panel.ZIndex="1000">
                    <!-- Backdrop bloqueante: captura TODOS los clicks para evitar
                         que el usuario interactúe con la app durante operaciones
                         críticas. NO tiene handler de cierre — sólo se cierra
                         programáticamente vía ControladorCarga.Ocultar(). -->
                    <Border Background="#E605050A"
                            IsHitTestVisible="True"
                            MouseLeftButtonDown="OverlayCarga_BloquearClick"
                            MouseRightButtonDown="OverlayCarga_BloquearClick"/>
                    <Border Background="#12121A"
                            BorderBrush="#2A2A35"
                            BorderThickness="2"
                            CornerRadius="20"
                            Width="550" Height="450"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Grid Margin="40">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                <TextBlock Text="O P E R A C I Ó N   E N   C U R S O"
                                           Foreground="#BD00FF" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtCargaSubtitulo"
                                           Text="Instalando Paquete"
                                           Foreground="#00D2FF" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Width="100" Height="100"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="0,20">
                                <Path Data="M 50,0 A 50,50 0 1 1 0,50"
                                      Stroke="#00D2FF" StrokeThickness="6"
                                      StrokeEndLineCap="Round" Stretch="None">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#00D2FF" BlurRadius="15" ShadowDepth="0"/>
                                    </Path.Effect>
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="GiroSpinner" CenterX="50" CenterY="50"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="GiroSpinner"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360"
                                                                     Duration="0:0:1"
                                                                     RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                                <TextBlock x:Name="TxtCargaPorcentaje"
                                           Text="0%" Foreground="White"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Row="2" Margin="0,0,0,30">
                                <Border Background="#1A1A24" CornerRadius="10"
                                        Height="12" BorderBrush="#2A2A35"
                                        BorderThickness="1" ClipToBounds="True"
                                        Margin="0,0,0,10">
                                    <Border x:Name="BarraProgresoNeon"
                                            Background="#00D2FF" Width="0"
                                            HorizontalAlignment="Left" CornerRadius="5">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#00D2FF" BlurRadius="10" ShadowDepth="0"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock x:Name="TxtCargaDetalle"
                                           Text="Preparando motores..."
                                           Foreground="#707080" FontSize="12"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <UniformGrid Grid.Row="3" Columns="2" Rows="2" Margin="10,0">
                                <TextBlock x:Name="TxtPaso1" Text="1. Descargando paquete"
                                           Foreground="#707080" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock x:Name="TxtPaso2" Text="2. Extrayendo archivos"
                                           Foreground="#707080" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock x:Name="TxtPaso3" Text="3. Aplicando en SD"
                                           Foreground="#707080" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock x:Name="TxtPaso4" Text="4. Limpiando temporales"
                                           Foreground="#707080" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,5"/>
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="GridPanelDerechoContenedor" Grid.Row="1" Grid.Column="2" Panel.ZIndex="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <controles:RetractilDer x:Name="ArsenalRetractil" Grid.Column="0"/>
                <controles:PanelDerecho x:Name="InfoSD" Grid.Column="1"/>
            </Grid>

            <!-- ══════════════════════════════════════════════
                 OVERLAY: Cola de Procesos (PS5-style)
                 ══════════════════════════════════════════════ -->
            <Grid x:Name="PanelQueueOverlay"
                  Grid.Row="0" Grid.RowSpan="2"
                  Grid.Column="0" Grid.ColumnSpan="3"
                  Visibility="Collapsed"
                  Panel.ZIndex="900">

                <!-- Click-away para cerrar -->
                <Border Background="Transparent"
                        MouseLeftButtonDown="BtnCerrarQueue_Click"/>

                <!-- Panel flotante bajo el top bar, alineado a la izquierda -->
                <Border Width="390" MaxHeight="560"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="180,52,0,0"
                        CornerRadius="0,0,16,16"
                        Background="#0C0C14"
                        BorderBrush="#2A2A35" BorderThickness="1,0,1,1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.7"/>
                    </Border.Effect>
                    <Border.Resources>
                        <Style x:Key="QueuePbStyle" TargetType="ProgressBar">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Border Background="#1A1A25" CornerRadius="2" ClipToBounds="True">
                                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00D2FF" Offset="0"/>
                                                        <GradientStop Color="#BD00FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Resources>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Cabecera -->
                        <Grid Grid.Row="0" Margin="16,14,12,12">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="COLA DE PROCESOS"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#00D2FF" Opacity="0.85"/>
                                <TextBlock Text="{Binding Source={x:Static core:Servicios.Cola}, Path=ContadorActivos,
                                                         StringFormat={}{0} proceso(s) activo(s)}"
                                           FontSize="10" Foreground="#707080" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Click="BtnCerrarQueue_Click">
                                <TextBlock Text="✕" FontSize="14" Foreground="#707080" Opacity="0.7"/>
                            </Button>
                        </Grid>

                        <Rectangle Grid.Row="0" Height="1" Fill="#2A2A35"
                                   VerticalAlignment="Bottom"/>

                        <!-- Lista de items -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Padding="12,8,12,0">
                            <ItemsControl ItemsSource="{Binding Source={x:Static core:Servicios.Cola}, Path=Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:ItemQueue}">
                                        <Border Margin="0,0,0,8" CornerRadius="10"
                                                Background="#12121C"
                                                BorderBrush="#2A2A35" BorderThickness="1"
                                                Padding="12,10">
                                            <StackPanel>
                                                <!-- Fila 1: Titulo + badge estado + cancelar -->
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding Titulo}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="White"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,110,0"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel HorizontalAlignment="Right"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <!-- Estado badge -->
                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#20707080"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="{x:Static models:EstadoQueue.EnProceso}">
                                                                            <Setter Property="Background" Value="#1800D2FF"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="{x:Static models:EstadoQueue.Completado}">
                                                                            <Setter Property="Background" Value="#1822C55E"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="{x:Static models:EstadoQueue.Error}">
                                                                            <Setter Property="Background" Value="#18EF4444"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding TextoEstado}" FontSize="9" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#707080"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="{x:Static models:EstadoQueue.EnProceso}">
                                                                                <Setter Property="Foreground" Value="#00D2FF"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="{x:Static models:EstadoQueue.Completado}">
                                                                                <Setter Property="Foreground" Value="#22C55E"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="{x:Static models:EstadoQueue.Error}">
                                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <!-- Botón cancelar (solo si activo) -->
                                                        <Button Tag="{Binding}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Cursor="Hand" VerticalAlignment="Center"
                                                                Click="BtnCancelarItemQueue_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding EsActivo}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Border Background="#20EF4444" CornerRadius="4" Padding="6,2">
                                                                <TextBlock Text="Cancelar" FontSize="9"
                                                                           FontWeight="Bold" Foreground="#EF4444"/>
                                                            </Border>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Barra de progreso -->
                                                <ProgressBar Value="{Binding Progreso}" Maximum="100" Height="4"
                                                             Margin="0,0,0,6"
                                                             Style="{StaticResource QueuePbStyle}"/>

                                                <!-- Mensaje estado -->
                                                <TextBlock Text="{Binding MensajeEstado}"
                                                           FontSize="9" Foreground="#707080"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Pie: limpiar completados -->
                        <Border Grid.Row="2" BorderBrush="#2A2A35" BorderThickness="0,1,0,0"
                                Padding="12,10">
                            <Grid>
                                <TextBlock Text="No hay procesos en cola"
                                           FontSize="10" Foreground="#707080"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Source={x:Static core:Servicios.Cola}, Path=TieneItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Content="LIMPIAR COMPLETADOS"
                                        HorizontalAlignment="Right"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" FontSize="10" FontWeight="Bold"
                                        Foreground="#707080"
                                        Click="BtnLimpiarQueue_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Source={x:Static core:Servicios.Cola}, Path=TieneItems}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 OVERLAY: Panel de Actualización de la App
                 ══════════════════════════════════════════════════════════ -->
            <Grid x:Name="PanelActualizacionOverlay"
                  Grid.Row="0" Grid.RowSpan="2"
                  Grid.Column="0" Grid.ColumnSpan="3"
                  Visibility="Collapsed"
                  Panel.ZIndex="901">

                <!-- Click-away para cerrar -->
                <Border Background="Transparent"
                        MouseLeftButtonDown="BtnCerrarActualizacion_Click"/>

                <!-- Panel flotante centrado bajo la top bar -->
                <Border Width="500" MaxHeight="560"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,52,0,0"
                        CornerRadius="0,0,20,20"
                        Background="#0A0A12"
                        BorderBrush="#2A2A35" BorderThickness="1,0,1,1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.85"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ── Cabecera ── -->
                        <Grid Grid.Row="0" Margin="20,16,16,0">
                            <StackPanel>
                                <TextBlock Text="✦  ACTUALIZACIÓN DISPONIBLE"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#22C55E" Opacity="0.9"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="NX-Suite"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="White"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Click="BtnCerrarActualizacion_Click">
                                <TextBlock Text="✕" FontSize="14" Foreground="#707080" Opacity="0.7"/>
                            </Button>
                        </Grid>
                        <Rectangle Grid.Row="0" Height="1" Fill="#2A2A35"
                                   VerticalAlignment="Bottom" Margin="0,52,0,0"/>

                        <!-- ── Cuerpo: versiones + notas ── -->
                        <StackPanel Grid.Row="1" Margin="20,20,20,8">

                            <!-- Comparativa de versiones -->
                            <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Versión actual -->
                                <Border Grid.Column="0" CornerRadius="10" Padding="16,10"
                                        Background="#12121C" BorderBrush="#2A2A35" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="VERSIÓN ACTUAL" FontSize="9" FontWeight="Bold"
                                                   Foreground="#505060" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtVersionActualOverlay"
                                                   Text="v—" FontSize="22" FontWeight="Bold"
                                                   Foreground="#505060" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Flecha -->
                                <TextBlock Grid.Column="1"
                                           Text="›" FontSize="32" Foreground="#22C55E"
                                           VerticalAlignment="Center" Margin="18,0"
                                           FontWeight="Bold"/>

                                <!-- Nueva versión -->
                                <Border Grid.Column="2" CornerRadius="10" Padding="16,10"
                                        Background="#081A0E" BorderBrush="#22C55E" BorderThickness="1.5">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#22C55E" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
                                    </Border.Effect>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="NUEVA VERSIÓN" FontSize="9" FontWeight="Bold"
                                                   Foreground="#22C55E" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtVersionNuevaOverlay"
                                                   Text="v—" FontSize="22" FontWeight="Bold"
                                                   Foreground="#22C55E" HorizontalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#22C55E" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Novedades / Changelog -->
                            <TextBlock Text="NOVEDADES" Foreground="#505060"
                                       FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border CornerRadius="10" Background="#0F0F18"
                                    BorderBrush="#2A2A35" BorderThickness="1"
                                    Padding="14,12" MaxHeight="160">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="TxtNotasActualizacion"
                                               Text="" Foreground="#A0A0B8"
                                               FontSize="12" TextWrapping="Wrap"
                                               LineHeight="22"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <!-- ── Barra de progreso de descarga (oculta inicialmente) ── -->
                        <StackPanel x:Name="PanelProgresoActualizacion"
                                    Grid.Row="2" Margin="20,0,20,14"
                                    Visibility="Collapsed">
                            <Border x:Name="ContenedorBarraActualizacion"
                                    Background="#12121C" CornerRadius="6" Height="10"
                                    BorderBrush="#2A2A35" BorderThickness="1"
                                    ClipToBounds="True" Margin="0,0,0,8">
                                <Border x:Name="BarraProgresoActualizacion"
                                        Width="0" HorizontalAlignment="Left"
                                        CornerRadius="6">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00D2FF" Offset="0"/>
                                            <GradientStop Color="#22C55E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#22C55E" BlurRadius="8" ShadowDepth="0"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                            <TextBlock x:Name="TxtEstadoActualizacion"
                                       Text="Preparando descarga..."
                                       Foreground="#707080" FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- ── Botones de acción ── -->
                        <Grid Grid.Row="3" Margin="16,0,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnRecordarMasTardeActualizacion"
                                    Grid.Column="0" Margin="0,0,6,0" Height="42"
                                    Content="MÁS TARDE"
                                    Click="BtnRecordarMasTarde_Click"
                                    Style="{StaticResource EstiloBotonMenu}"/>

                            <Button x:Name="BtnActualizarAhora"
                                    Grid.Column="1" Margin="6,0,0,0" Height="42"
                                    Content="ACTUALIZAR AHORA"
                                    Click="BtnActualizarAhora_Click"
                                    Style="{StaticResource EstiloBotonInstalar}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════════
                 OVERLAY: Formateo FAT32 — frosted glass + SafeButton hold-to-confirm.
                 Lee la SD activa del panel derecho (no tiene combo propio). Sin
                 botón ✕ ni Refrescar: cierra con click fuera o desconexión de la SD.
                 La pantalla de carga global (OverlayCarga) muestra el progreso.
                 ══════════════════════════════════════════════════════════════════ -->
            <Grid x:Name="PanelFormatoFAT32Overlay"
                  Grid.Row="0" Grid.RowSpan="2"
                  Grid.Column="0" Grid.ColumnSpan="3"
                  Visibility="Collapsed"
                  Panel.ZIndex="860">

                <!-- Backdrop: click fuera = cerrar -->
                <Border Background="{StaticResource OverlayBackdropBrush}"
                        MouseLeftButtonDown="PanelFormato_BackdropClick"/>

                <Border Style="{StaticResource EstiloOverlayPanel}" Width="640">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header cian -->
                        <Border Grid.Row="0" Style="{StaticResource EstiloOverlayHeader}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="{StaticResource OverlayAcentoCian}"
                                        Margin="0,0,12,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00D2FF" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.9"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="FORMATEAR EN FAT32"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource OverlayAcentoCian}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Cuerpo -->
                        <StackPanel Grid.Row="1" Margin="24,22,24,18">

                            <!-- Tarjeta SD (read-only desde panel derecho) -->
                            <Border Style="{StaticResource EstiloOverlayTarjetaSD}"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="#1400D2FF" CornerRadius="8"
                                            Padding="14,4" Margin="0,0,14,0">
                                        <TextBlock x:Name="TxtLetraSDFormato"
                                                   Text="—" FontSize="26" FontWeight="Black"
                                                   Foreground="{StaticResource OverlayAcentoCian}"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtNombreSDFormato"
                                                   Text="Sin SD seleccionada"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource OverlayTextoTitulo}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="TxtInfoSDFormato"
                                                   Text="Selecciona una SD en el panel derecho"
                                                   FontSize="12"
                                                   Foreground="{StaticResource OverlayTextoSecundario}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <Border Grid.Column="2" Background="#0A0A18"
                                            CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="MICRO SD" FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource OverlayTextoApagado}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Aviso amber: visible cuando no hay SD válida -->
                            <Border x:Name="AvisoSinSDFormato"
                                    Style="{StaticResource EstiloOverlayAviso}"
                                    Margin="0,0,0,14"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠" FontSize="16"
                                               Foreground="{StaticResource OverlayAcentoAmber}"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#C0A050"
                                               FontSize="12" VerticalAlignment="Center">
                                        Selecciona una <Run FontWeight="Bold" Foreground="{StaticResource OverlayAcentoAmber}">microSD</Run> en el panel derecho para continuar.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Warning destructivo: visible siempre (es destructivo) -->
                            <Border Style="{StaticResource EstiloOverlayWarning}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="⚠" FontSize="18" Foreground="#FF6B6B"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" TextWrapping="Wrap" Foreground="#FFD0D0"
                                               FontSize="13" LineHeight="20" VerticalAlignment="Center">
                                        <Run FontWeight="Bold" Foreground="#EF4444">ATENCIÓN:</Run>
                                        <Run>se BORRARÁN todos los datos de la microSD.</Run>
                                        <Run>La unidad quedará formateada como</Run>
                                        <Run FontWeight="Bold" Foreground="White">FAT32 con etiqueta "SWITCH SD"</Run><Run>.</Run>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Footer -->
                        <Border Grid.Row="2" Style="{StaticResource EstiloOverlayFooter}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="TxtEstadoFormato" Grid.Column="0"
                                           Text="Mantén pulsado para confirmar"
                                           Foreground="{StaticResource OverlayTextoApagado}"
                                           FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <controles:SafeButton x:Name="BtnFormatearAhora"
                                        Grid.Column="1"
                                        IsEnabled="False"
                                        Width="200" Height="40"
                                        HoldTimeSeconds="2"
                                        IsSafeMode="True"
                                        Style="{StaticResource EstiloBotonEliminarHold}"
                                        Click="BtnFormatearAhora_Click">
                                    <TextBlock Text="FORMATEAR"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </controles:SafeButton>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════════
                 OVERLAY: Particionado y Formateo SD — frosted glass, acento púrpura.
                 Lee SD del panel derecho. Sin botones ✕ ni Refrescar: cierra con
                 click fuera o desconexión de la SD. La pantalla de carga global
                 (OverlayCarga) muestra el progreso de la operación.
                 ══════════════════════════════════════════════════════════════════ -->
            <Grid x:Name="PanelParticionadoOverlay"
                  Grid.Row="0" Grid.RowSpan="2"
                  Grid.Column="0" Grid.ColumnSpan="3"
                  Visibility="Collapsed"
                  Panel.ZIndex="870">

                <!-- Backdrop: click fuera = cerrar -->
                <Border Background="{StaticResource OverlayBackdropBrush}"
                        MouseLeftButtonDown="PanelParticionado_BackdropClick"/>

                <Border Style="{StaticResource EstiloOverlayPanel}" Width="700">

                    <Border.Resources>
                        <!-- Slider con acento purple -->
                        <Style x:Key="SliderParticionado" TargetType="Slider">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Slider">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Height="6" CornerRadius="3"
                                                    Background="#1A1A28" Margin="8,0">
                                                <Border HorizontalAlignment="Left" CornerRadius="3"
                                                        Background="#BD00FF" Width="0"/>
                                            </Border>
                                            <Track Grid.Row="0" x:Name="PART_Track" Margin="0,-6,0,-6">
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Width="20" Height="20" CornerRadius="4"
                                                                        Background="#BD00FF"
                                                                        BorderBrush="#80FFFFFF" BorderThickness="1">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0"
                                                                                          Color="#BD00FF" Opacity="0.8"/>
                                                                    </Border.Effect>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Resources>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header púrpura -->
                        <Border Grid.Row="0" Style="{StaticResource EstiloOverlayHeader}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="{StaticResource OverlayAcentoPurple}"
                                        Margin="0,0,12,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#BD00FF" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.9"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="PARTICIONAR Y FORMATEAR SD"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource OverlayAcentoPurple}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Cuerpo -->
                        <StackPanel Grid.Row="1" Margin="24,22,24,16">

                            <!-- Tarjeta SD (read-only desde panel derecho) -->
                            <Border Style="{StaticResource EstiloOverlayTarjetaSD}"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="#14BD00FF" CornerRadius="8"
                                            Padding="14,4" Margin="0,0,14,0">
                                        <TextBlock x:Name="TxtLetraSDParticionado"
                                                   Text="—" FontSize="26" FontWeight="Black"
                                                   Foreground="{StaticResource OverlayAcentoPurple}"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtNombreSDParticionado"
                                                   Text="Sin SD seleccionada"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource OverlayTextoTitulo}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="TxtInfoSDParticionado"
                                                   Text="Selecciona una SD en el panel derecho"
                                                   FontSize="12"
                                                   Foreground="{StaticResource OverlayTextoSecundario}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <Border Grid.Column="2" Background="#0A0A18"
                                            CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="MICRO SD" FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource OverlayTextoApagado}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Aviso amber: visible cuando no hay SD válida -->
                            <Border x:Name="AvisoSinSDParticionado"
                                    Style="{StaticResource EstiloOverlayAviso}"
                                    Margin="0,0,0,16"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠" FontSize="16"
                                               Foreground="{StaticResource OverlayAcentoAmber}"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#C0A050"
                                               FontSize="12" VerticalAlignment="Center">
                                        Selecciona una <Run FontWeight="Bold" Foreground="{StaticResource OverlayAcentoAmber}">microSD</Run> en el panel derecho para continuar.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Tamaño emuMMC -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="TAMAÑO EMUMMC" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource OverlayTextoApagado}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TxtGbValorParticionado"
                                               Text="12 GB" FontSize="30" FontWeight="Black"
                                               Foreground="{StaticResource OverlayAcentoPurple}"/>
                                </StackPanel>
                                <Border Grid.Column="1" x:Name="BadgeRecParticionado"
                                        Background="#14BD00FF" CornerRadius="6"
                                        Padding="10,5" VerticalAlignment="Center" Margin="0,18,0,0">
                                    <TextBlock Text="RECOMENDADO" FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource OverlayAcentoPurple}"/>
                                </Border>
                            </Grid>

                            <Slider x:Name="SliderGbParticionado"
                                    Minimum="0" Maximum="7" Value="2"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    Style="{StaticResource SliderParticionado}"
                                    ValueChanged="SliderGbParticionado_ValueChanged"
                                    Margin="0,0,0,6"/>

                            <Grid Margin="10,0,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="4"  FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="8"  FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="12" FontSize="10" Foreground="{StaticResource OverlayAcentoPurple}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="16" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="24" FontSize="10" Foreground="{StaticResource OverlayAcentoPurple}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="32" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="48" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="7" Text="64" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="GB" FontSize="9"
                                       Foreground="{StaticResource OverlayTextoApagado}"
                                       HorizontalAlignment="Right" Margin="0,2,10,16"/>

                            <!-- Warning destructivo -->
                            <Border Style="{StaticResource EstiloOverlayWarning}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="⚠" FontSize="18" Foreground="#FF6B6B"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" TextWrapping="Wrap" Foreground="#FFD0D0"
                                               FontSize="13" LineHeight="20" VerticalAlignment="Center">
                                        <Run FontWeight="Bold" Foreground="#EF4444">ATENCIÓN:</Run>
                                        <Run>se BORRARÁN todos los datos de la microSD.</Run>
                                        <Run>Quedará dividida en</Run>
                                        <Run FontWeight="Bold" Foreground="White">SWITCH SD (FAT32) + emuMMC</Run><Run>.</Run>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Footer -->
                        <Border Grid.Row="2" Style="{StaticResource EstiloOverlayFooter}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="TxtEstadoParticionado" Grid.Column="0"
                                           Text="Mantén pulsado para confirmar"
                                           Foreground="{StaticResource OverlayTextoApagado}"
                                           FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <controles:SafeButton x:Name="BtnParticionarAhora"
                                        Grid.Column="1"
                                        IsEnabled="False"
                                        Width="240" Height="40"
                                        HoldTimeSeconds="2"
                                        IsSafeMode="True"
                                        Style="{StaticResource EstiloBotonEliminarHold}"
                                        Click="BtnParticionarAhora_Click">
                                    <TextBlock Text="FORMATEAR Y PARTICIONAR"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </controles:SafeButton>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════════
                 OVERLAY: Asistido Completo — frosted glass, acento cian.
                 Particiona la SD del panel derecho + instala los módulos
                 recomendados (con sus dependencias) en una sola operación.
                 Lee SD del panel derecho. Sin ✕ ni Refrescar. La pantalla de
                 carga global muestra el progreso real de la operación.
                 ══════════════════════════════════════════════════════════════════ -->
            <Grid x:Name="PanelAsistidoCompletoOverlay"
                  Grid.Row="0" Grid.RowSpan="2"
                  Grid.Column="0" Grid.ColumnSpan="3"
                  Visibility="Collapsed"
                  Panel.ZIndex="880">

                <!-- Backdrop: click fuera = cerrar -->
                <Border Background="{StaticResource OverlayBackdropBrush}"
                        MouseLeftButtonDown="PanelAsistidoCompleto_BackdropClick"/>

                <Border Style="{StaticResource EstiloOverlayPanel}" Width="780" MaxHeight="640">

                    <Border.Resources>
                        <!-- Slider con acento cian -->
                        <Style x:Key="SliderAsistidoCian" TargetType="Slider">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Slider">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Height="6" CornerRadius="3"
                                                    Background="#1A1A28" Margin="8,0">
                                                <Border HorizontalAlignment="Left" CornerRadius="3"
                                                        Background="#00D2FF" Width="0"/>
                                            </Border>
                                            <Track Grid.Row="0" x:Name="PART_Track" Margin="0,-6,0,-6">
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Width="20" Height="20" CornerRadius="4"
                                                                        Background="#00D2FF"
                                                                        BorderBrush="#80FFFFFF" BorderThickness="1">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0"
                                                                                          Color="#00D2FF" Opacity="0.8"/>
                                                                    </Border.Effect>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <!-- Tarjeta de módulo recomendado (cian) -->
                        <DataTemplate x:Key="PlantillaModuloRecomendado">
                            <Border CornerRadius="10" Background="#0F0F18"
                                    BorderBrush="#252530" BorderThickness="1"
                                    Padding="12,10" Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30" Height="30" CornerRadius="7"
                                            Margin="0,0,10,0" Background="#14FFFFFF">
                                        <Image Source="{Binding Modulo.IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Modulo.Nombre}"
                                                       FontSize="12" FontWeight="Bold" Foreground="White"/>
                                            <Border Background="#1400D2FF" CornerRadius="4"
                                                    Padding="5,1" Margin="6,0,0,0"
                                                    Visibility="{Binding VersionFijadaVisible}">
                                                <TextBlock Text="{Binding EtiquetaVersion}"
                                                           FontSize="8" Foreground="#00D2FF" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Nota}" FontSize="9" Foreground="#505060"
                                                   Visibility="{Binding NotaVisible}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>

                        <!-- Tarjeta de dependencia (amber) -->
                        <DataTemplate x:Key="PlantillaModuloDependencia">
                            <Border CornerRadius="10" Background="#0C0C10"
                                    BorderBrush="#44FFD54A" BorderThickness="1"
                                    Padding="12,10" Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30" Height="30" CornerRadius="7"
                                            Margin="0,0,10,0" Background="#18FFD54A">
                                        <Image Source="{Binding IconoUrl, Converter={StaticResource IconoCacheConverter}}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nombre}"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="#FFD54A"/>
                                        <TextBlock Text="dep. automática"
                                                   FontSize="9" Foreground="#806040"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </Border.Resources>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header cian -->
                        <Border Grid.Row="0" Style="{StaticResource EstiloOverlayHeader}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="{StaticResource OverlayAcentoCian}"
                                        Margin="0,0,12,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00D2FF" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.9"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="ASISTIDO COMPLETO"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource OverlayAcentoCian}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Cuerpo scrollable -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="24,20,24,16">
                            <StackPanel>

                                <!-- Tarjeta SD (read-only desde panel derecho) -->
                                <Border Style="{StaticResource EstiloOverlayTarjetaSD}"
                                        Margin="0,0,0,18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="#1400D2FF" CornerRadius="8"
                                                Padding="14,4" Margin="0,0,14,0">
                                            <TextBlock x:Name="TxtLetraSDAsistido"
                                                       Text="—" FontSize="26" FontWeight="Black"
                                                       Foreground="{StaticResource OverlayAcentoCian}"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="TxtNombreSDAsistido"
                                                       Text="Sin SD seleccionada"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource OverlayTextoTitulo}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TxtInfoSDAsistido"
                                                       Text="Selecciona una SD en el panel derecho"
                                                       FontSize="12"
                                                       Foreground="{StaticResource OverlayTextoSecundario}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="2" Background="#0A0A18"
                                                CornerRadius="6" Padding="8,4">
                                            <TextBlock Text="MICRO SD" FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource OverlayTextoApagado}"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Aviso amber: visible cuando no hay SD válida -->
                                <Border x:Name="AvisoSinSDAsistido"
                                        Style="{StaticResource EstiloOverlayAviso}"
                                        Margin="0,0,0,16"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠" FontSize="16"
                                                   Foreground="{StaticResource OverlayAcentoAmber}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock TextWrapping="Wrap"
                                                   Foreground="#C0A050"
                                                   FontSize="12" VerticalAlignment="Center">
                                            Selecciona una <Run FontWeight="Bold" Foreground="{StaticResource OverlayAcentoAmber}">microSD</Run> en el panel derecho para continuar.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Tamaño emuMMC -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="TAMAÑO EMUMMC" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource OverlayTextoApagado}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock x:Name="TxtGbValorAsistido"
                                                   Text="12 GB" FontSize="30" FontWeight="Black"
                                                   Foreground="{StaticResource OverlayAcentoCian}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" x:Name="BadgeRecAsistido"
                                            Background="#1400D2FF" CornerRadius="6"
                                            Padding="10,5" VerticalAlignment="Center" Margin="0,18,0,0">
                                        <TextBlock Text="RECOMENDADO" FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource OverlayAcentoCian}"/>
                                    </Border>
                                </Grid>

                                <Slider x:Name="SliderGbAsistido"
                                        Minimum="0" Maximum="7" Value="2"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        Style="{StaticResource SliderAsistidoCian}"
                                        ValueChanged="SliderGbAsistido_ValueChanged"
                                        Margin="0,0,0,6"/>

                                <Grid Margin="10,0,10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="4"  FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="8"  FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="12" FontSize="10" Foreground="{StaticResource OverlayAcentoCian}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="16" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="24" FontSize="10" Foreground="{StaticResource OverlayAcentoCian}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="32" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="6" Text="48" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="7" Text="64" FontSize="10" Foreground="{StaticResource OverlayTextoApagado}" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="GB" FontSize="9"
                                           Foreground="{StaticResource OverlayTextoApagado}"
                                           HorizontalAlignment="Right" Margin="0,2,10,18"/>

                                <!-- Módulos principales -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="5" Height="14" CornerRadius="3"
                                            Background="{StaticResource OverlayAcentoCian}" Margin="0,0,10,0"/>
                                    <TextBlock Text="MÓDULOS PRINCIPALES"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource OverlayTextoApagado}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ItemsControl x:Name="ListaModulosAsistido"
                                              ItemTemplate="{StaticResource PlantillaModuloRecomendado}"
                                              Margin="0,0,0,14">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <!-- Dependencias automáticas (amber) -->
                                <Border x:Name="PanelDepsAsistido"
                                        Visibility="Collapsed"
                                        CornerRadius="12" BorderThickness="1"
                                        BorderBrush="#55FFD54A" Background="#06FFD54A"
                                        Padding="16,14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Width="5" Height="14" CornerRadius="3"
                                                    Background="{StaticResource OverlayAcentoAmber}" Margin="0,0,10,0"/>
                                            <TextBlock Text="DEPENDENCIAS AUTOMÁTICAS"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource OverlayAcentoAmber}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="#A08050"
                                                   TextWrapping="Wrap" Margin="0,0,0,10">
                                            <Run>Estos módulos son requeridos por los principales y se instalarán automáticamente </Run><Run FontWeight="Bold" Foreground="{StaticResource OverlayAcentoAmber}">antes</Run><Run> que el resto.</Run>
                                        </TextBlock>
                                        <ItemsControl x:Name="ListaDepsAsistido"
                                                      ItemTemplate="{StaticResource PlantillaModuloDependencia}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Warning destructivo -->
                                <Border Style="{StaticResource EstiloOverlayWarning}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="⚠" FontSize="18" Foreground="#FF6B6B"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" TextWrapping="Wrap" Foreground="#FFD0D0"
                                                   FontSize="13" LineHeight="20" VerticalAlignment="Center">
                                            <Run FontWeight="Bold" Foreground="#EF4444">ATENCIÓN:</Run>
                                            <Run>se BORRARÁN todos los datos de la microSD.</Run>
                                            <Run>La SD será reparticionada y se instalarán los módulos listados arriba.</Run>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="2" Style="{StaticResource EstiloOverlayFooter}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="TxtEstadoAsistido" Grid.Column="0"
                                           Text="Mantén pulsado para confirmar"
                                           Foreground="{StaticResource OverlayTextoApagado}"
                                           FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <controles:SafeButton x:Name="BtnIniciarAsistido"
                                        Grid.Column="1"
                                        IsEnabled="False"
                                        Width="240" Height="40"
                                        HoldTimeSeconds="2"
                                        IsSafeMode="True"
                                        Style="{StaticResource EstiloBotonEliminarHold}"
                                        Click="BtnIniciarAsistido_Click">
                                    <TextBlock Text="INICIAR PROCESO COMPLETO"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </controles:SafeButton>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════════
                 OVERLAY: Dependencias — Frosted glass con tarjetas reales del catálogo.
                 El blur del MainGrid + el fondo semitransparente crean el efecto de
                 vidrio empañado. Las tarjetas usan exactamente la misma PlantillaModuloGamer
                 del catálogo, por lo que el progreso de instalación es visible en cada una.
                 ══════════════════════════════════════════════════════════════════ -->
            <Grid x:Name="PanelDependenciasOverlay"
                  Grid.Row="0" Grid.RowSpan="2"
                  Grid.Column="0" Grid.ColumnSpan="3"
                  Visibility="Collapsed"
                  Panel.ZIndex="850">

            <!-- Backdrop: click fuera = cerrar (sólo si no hay instalación activa) -->
            <Border Background="#CC000008"
                    MouseLeftButtonDown="OverlayDepsBackdrop_MouseDown"/>

            <!-- ═══════════════════════════════════════════════
                 Mesa de crafteo — Minecraft style
                 ═══════════════════════════════════════════════ -->
            <Border x:Name="PanelCrafteo"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="20"
                    BorderThickness="2"
                    Background="#0C0C1A">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="PincelBordeCrafteo" Color="#2A2A40"/>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="80" ShadowDepth="0"
                                      Color="Black" Opacity="0.97"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- header amber -->
                        <RowDefinition Height="Auto"/>  <!-- crafteo -->
                        <RowDefinition Height="Auto"/>  <!-- status -->
                    </Grid.RowDefinitions>

                    <!-- Header amber -->
                    <Border Grid.Row="0"
                            Background="#08FFFFFF"
                            CornerRadius="18,18,0,0"
                            Padding="24,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="#FFD54A" Margin="0,0,10,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FFD54A" BlurRadius="10"
                                                      ShadowDepth="0" Opacity="0.9"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="INSTALAR DEPENDENCIAS"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#FFD54A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Cuerpo: tres columnas (ingredientes | flecha | resultado) -->
                    <Grid Grid.Row="1" Margin="28,20,28,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- ingredientes -->
                            <ColumnDefinition Width="110"/>   <!-- flecha -->
                            <ColumnDefinition Width="Auto"/>  <!-- resultado -->
                        </Grid.ColumnDefinitions>

                        <!-- ── INGREDIENTES (deps B, C…) ── -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="DEPENDENCIAS"
                                       Foreground="#404060" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <Border Grid.Row="1"
                                    Background="#080812"
                                    CornerRadius="12" BorderThickness="2" Padding="4">
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="PincelBordeIngredientes" Color="#1A1A30"/>
                                </Border.BorderBrush>
                                <!-- Cards de deps con botones activos -->
                                <ItemsControl x:Name="ListaDepOverlay"
                                              IsHitTestVisible="True"
                                              ButtonBase.Click="DepCatalogo_ClickBoton"
                                              ItemTemplate="{StaticResource PlantillaModuloGamer}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel HorizontalAlignment="Center" MaxWidth="700"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Border>
                        </Grid>

                        <!-- ── FLECHA (animada al desbloquear A) ── -->
                        <Grid Grid.Column="1"
                              VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path x:Name="FlechaCrafteo"
                                  Data="M 0,0 L 52,0 M 37,-13 L 52,0 L 37,13"
                                  StrokeThickness="3.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round">
                                <Path.Stroke>
                                    <SolidColorBrush x:Name="PincelFlecha" Color="#1E1E38"/>
                                </Path.Stroke>
                                <Path.Effect>
                                    <DropShadowEffect x:Name="GlowFlecha"
                                                      Color="#40C057" BlurRadius="0"
                                                      ShadowDepth="0" Opacity="0"/>
                                </Path.Effect>
                            </Path>
                        </Grid>

                        <!-- ── RESULTADO (módulo A, apagado hasta que deps listas) ── -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="RESULTADO"
                                       Foreground="#404060" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

                            <Border Grid.Row="1" x:Name="BordeResultado"
                                    Background="#080812"
                                    CornerRadius="12" BorderThickness="2" Padding="4">
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="PincelBordeResultado" Color="#1A1A30"/>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect x:Name="GlowResultado"
                                                      Color="#40C057" BlurRadius="0"
                                                      ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>

                                <!-- A: apagada (Opacity baja, IsHitTestVisible=False)
                                     Se enciende cuando todos los ingredientes están listos -->
                                <Grid x:Name="ContenedorResultadoA"
                                      Opacity="0.28"
                                      IsHitTestVisible="False"
                                      ButtonBase.Click="ResultadoCatalogo_ClickBoton">
                                    <ItemsControl x:Name="ListaResultadoA"
                                                  IsHitTestVisible="True"
                                                  ItemTemplate="{StaticResource PlantillaModuloGamer}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Status strip -->
                    <Border Grid.Row="2"
                            Background="#060610"
                            CornerRadius="0,0,18,18"
                            Padding="28,10">
                        <TextBlock x:Name="TxtEstadoCrafteo"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#606075"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            </Grid>

        </Grid>
    </Border>
</Window>